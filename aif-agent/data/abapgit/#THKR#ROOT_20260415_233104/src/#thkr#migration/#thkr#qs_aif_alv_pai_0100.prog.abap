MODULE user_command_0100 INPUT.
  CASE ref_alv->ok_code.
    WHEN 'BACK' OR 'EXIT' OR 'CANCEL'.
      CLEAR gt_alv_t_fmap[].
      ref_alv->update_grid( ).
      LEAVE TO SCREEN 0.
  ENDCASE.
  CLEAR ref_alv->ok_code.
ENDMODULE.
