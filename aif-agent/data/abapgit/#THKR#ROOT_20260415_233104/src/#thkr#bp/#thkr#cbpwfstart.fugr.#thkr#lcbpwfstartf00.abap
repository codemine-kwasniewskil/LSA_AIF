*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: /THKR/V_ACTFIELD................................*
FORM GET_DATA_/THKR/V_ACTFIELD.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM /THKR/CBACTFIELD WHERE
(VIM_WHERETAB) .
    CLEAR /THKR/V_ACTFIELD .
/THKR/V_ACTFIELD-MANDT =
/THKR/CBACTFIELD-MANDT .
/THKR/V_ACTFIELD-OBJECT =
/THKR/CBACTFIELD-OBJECT .
/THKR/V_ACTFIELD-TABNAME =
/THKR/CBACTFIELD-TABNAME .
/THKR/V_ACTFIELD-AKTION =
/THKR/CBACTFIELD-AKTION .
/THKR/V_ACTFIELD-FIELDNAME =
/THKR/CBACTFIELD-FIELDNAME .
/THKR/V_ACTFIELD-ONLY_FILL =
/THKR/CBACTFIELD-ONLY_FILL .
/THKR/V_ACTFIELD-ONLY_CLEAR =
/THKR/CBACTFIELD-ONLY_CLEAR .
<VIM_TOTAL_STRUC> = /THKR/V_ACTFIELD.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_ACTFIELD .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_ACTFIELD.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_ACTFIELD-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/CBACTFIELD WHERE
  OBJECT = /THKR/V_ACTFIELD-OBJECT AND
  TABNAME = /THKR/V_ACTFIELD-TABNAME AND
  AKTION = /THKR/V_ACTFIELD-AKTION AND
  FIELDNAME = /THKR/V_ACTFIELD-FIELDNAME .
    IF SY-SUBRC = 0.
    DELETE /THKR/CBACTFIELD .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/CBACTFIELD WHERE
  OBJECT = /THKR/V_ACTFIELD-OBJECT AND
  TABNAME = /THKR/V_ACTFIELD-TABNAME AND
  AKTION = /THKR/V_ACTFIELD-AKTION AND
  FIELDNAME = /THKR/V_ACTFIELD-FIELDNAME .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/CBACTFIELD.
    ENDIF.
/THKR/CBACTFIELD-MANDT =
/THKR/V_ACTFIELD-MANDT .
/THKR/CBACTFIELD-OBJECT =
/THKR/V_ACTFIELD-OBJECT .
/THKR/CBACTFIELD-TABNAME =
/THKR/V_ACTFIELD-TABNAME .
/THKR/CBACTFIELD-AKTION =
/THKR/V_ACTFIELD-AKTION .
/THKR/CBACTFIELD-FIELDNAME =
/THKR/V_ACTFIELD-FIELDNAME .
/THKR/CBACTFIELD-ONLY_FILL =
/THKR/V_ACTFIELD-ONLY_FILL .
/THKR/CBACTFIELD-ONLY_CLEAR =
/THKR/V_ACTFIELD-ONLY_CLEAR .
    IF SY-SUBRC = 0.
    UPDATE /THKR/CBACTFIELD ##WARN_OK.
    ELSE.
    INSERT /THKR/CBACTFIELD .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_ACTFIELD-UPD_FLAG,
STATUS_/THKR/V_ACTFIELD-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
*---------------------------------------------------------------------*
FORM READ_SINGLE_/THKR/V_ACTFIELD.
  SELECT SINGLE * FROM /THKR/CBACTFIELD WHERE
OBJECT = /THKR/V_ACTFIELD-OBJECT AND
TABNAME = /THKR/V_ACTFIELD-TABNAME AND
AKTION = /THKR/V_ACTFIELD-AKTION AND
FIELDNAME = /THKR/V_ACTFIELD-FIELDNAME .
/THKR/V_ACTFIELD-MANDT =
/THKR/CBACTFIELD-MANDT .
/THKR/V_ACTFIELD-OBJECT =
/THKR/CBACTFIELD-OBJECT .
/THKR/V_ACTFIELD-TABNAME =
/THKR/CBACTFIELD-TABNAME .
/THKR/V_ACTFIELD-AKTION =
/THKR/CBACTFIELD-AKTION .
/THKR/V_ACTFIELD-FIELDNAME =
/THKR/CBACTFIELD-FIELDNAME .
/THKR/V_ACTFIELD-ONLY_FILL =
/THKR/CBACTFIELD-ONLY_FILL .
/THKR/V_ACTFIELD-ONLY_CLEAR =
/THKR/CBACTFIELD-ONLY_CLEAR .
ENDFORM.
*---------------------------------------------------------------------*
FORM CORR_MAINT_/THKR/V_ACTFIELD USING VALUE(CM_ACTION) RC.
  DATA: RETCODE LIKE SY-SUBRC, COUNT TYPE I, TRSP_KEYLEN TYPE SYFLENG.
  FIELD-SYMBOLS: <TAB_KEY_X> TYPE X.
  CLEAR RC.
MOVE /THKR/V_ACTFIELD-OBJECT TO
/THKR/CBACTFIELD-OBJECT .
MOVE /THKR/V_ACTFIELD-TABNAME TO
/THKR/CBACTFIELD-TABNAME .
MOVE /THKR/V_ACTFIELD-AKTION TO
/THKR/CBACTFIELD-AKTION .
MOVE /THKR/V_ACTFIELD-FIELDNAME TO
/THKR/CBACTFIELD-FIELDNAME .
MOVE /THKR/V_ACTFIELD-MANDT TO
/THKR/CBACTFIELD-MANDT .
  CORR_KEYTAB             =  E071K.
  CORR_KEYTAB-OBJNAME     = '/THKR/CBACTFIELD'.
  IF NOT <vim_corr_keyx> IS ASSIGNED.
    ASSIGN CORR_KEYTAB-TABKEY TO <vim_corr_keyx> CASTING.
  ENDIF.
  ASSIGN /THKR/CBACTFIELD TO <TAB_KEY_X> CASTING.
  PERFORM VIM_GET_TRSPKEYLEN
    USING '/THKR/CBACTFIELD'
    CHANGING TRSP_KEYLEN.
  <VIM_CORR_KEYX>(TRSP_KEYLEN) = <TAB_KEY_X>(TRSP_KEYLEN).
  PERFORM UPDATE_CORR_KEYTAB USING CM_ACTION RETCODE.
  ADD: RETCODE TO RC, 1 TO COUNT.
  IF RC LT COUNT AND CM_ACTION NE PRUEFEN.
    CLEAR RC.
  ENDIF.

ENDFORM.
