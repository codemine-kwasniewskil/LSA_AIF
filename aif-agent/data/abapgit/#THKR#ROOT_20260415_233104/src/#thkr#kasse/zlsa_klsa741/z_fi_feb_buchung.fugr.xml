    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>ZFI_FEB_CALL_FB09</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0004</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00025</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>ZFI_FEB_CALL_FB09</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00004</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;FUNCTIONALITY&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Funktionsbaustein nimmt einen Ausgleichsvorgang zurück bzw. prüft,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ob dies möglich ist.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Beispiele für den Aufruf findet man in den Modulepools SAPMF05R</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(Transaktion FBRA - Rücknahme Ausgleich mit Storno des</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Ausgleichsbelegs) und SAPMFCHK (Transaktion FCH8 - Rücknahme einer</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Scheckzahlung).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es sind die drei Parameter der Transaktion FBRA zu übergeben. Im</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Gegensatz zur Transaktion FBRA geht der Funktionsbaustein davon aus,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>daß ein ggf. notwendiger Storno des Ausgleichsbelegs (z.B. bei</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Ausgleich in Drittwährung, bei Kursdifferenzen oder bei Ausgleich eines</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Nettobelegs) vom Aufrufer durchgeführt wird. Im Simulationsmodus</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>gestartet wird nur geprüft, ob eine Rücknahme des Ausgleichsvorgangs</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>möglich wäre.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Über die optionalen Parameter können der Transaktion die Anweisungen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>gegeben werden, die online über Popups zu geben sind: Korrespondenz</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>erledigen, weitere Konten selektieren, ggf. das Ausgleichsdatum</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>angegeben, wenn nur weitere Konten selektiert werden sollen (bei den</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>&apos;Restarbeiten&apos; einer unvollständig durchgeführten Rücknahme).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U4</TDFORMAT>
       <TDLINE>&amp;FURTHER_SOURCES_OF_INF&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Wurde die Exception ausgelöst, so kann über die Systemfelder SY-MSGID,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>SY-MSGNO, SY-MSGV1, SY-MSGV2, etc. der Grund ausgegeben werden, warum</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>der Ausgleich nicht zurückgenommen werden kann.</TDLINE>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS_ZFI_FEB_CALL_FB09>
