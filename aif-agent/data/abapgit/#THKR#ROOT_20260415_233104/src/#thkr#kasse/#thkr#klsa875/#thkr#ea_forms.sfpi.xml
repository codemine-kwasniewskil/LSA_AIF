      <FPCLINE>CALL FUNCTION &apos;BAPI_USER_GET_DETAIL&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    username = sy-uname</FPCLINE>
      <FPCLINE>  IMPORTING</FPCLINE>
      <FPCLINE>    address  = ls_address</FPCLINE>
      <FPCLINE>  TABLES</FPCLINE>
      <FPCLINE>    return   = lt_return.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF NOT ls_address IS INITIAL.</FPCLINE>
      <FPCLINE>* Telefon</FPCLINE>
      <FPCLINE>  IF NOT ls_address-tel1_ext IS INITIAL.</FPCLINE>
      <FPCLINE>    CONCATENATE ls_address-tel1_numbr &apos;-&apos; ls_address-tel1_ext INTO gs_user_data-tel.</FPCLINE>
      <FPCLINE>  ELSE.</FPCLINE>
      <FPCLINE>    MOVE ls_address-tel1_numbr TO gs_user_data-tel.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>* Fax</FPCLINE>
      <FPCLINE>  IF NOT ls_address-fax_extens IS INITIAL.</FPCLINE>
      <FPCLINE>    CONCATENATE ls_address-fax_number &apos;-&apos; ls_address-fax_extens INTO gs_user_data-fax.</FPCLINE>
      <FPCLINE>  ELSE.</FPCLINE>
      <FPCLINE>    MOVE ls_address-fax_number TO gs_user_data-fax.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>* Nachname</FPCLINE>
      <FPCLINE>  IF NOT ls_address-title_p IS INITIAL.</FPCLINE>
      <FPCLINE>    CONCATENATE ls_address-title_p ls_address-lastname</FPCLINE>
      <FPCLINE>    INTO gs_user_data-name SEPARATED BY space.</FPCLINE>
      <FPCLINE>  ELSE.</FPCLINE>
      <FPCLINE>    MOVE ls_address-lastname TO gs_user_data-name.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>* Funktion - Bereich und Kennung</FPCLINE>
      <FPCLINE>  MOVE ls_address-function TO gs_user_data-function.</FPCLINE>
      <FPCLINE>  MOVE ls_address-lastname TO gv_bearbeiter.</FPCLINE>
      <FPCLINE>* Abteilung</FPCLINE>
      <FPCLINE>  MOVE ls_address-department TO gs_user_data-abteilung.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>lv_obname = &apos;Z_LSA_LOGO_B&apos;. &quot;Version ohne Linie</FPCLINE>
      <FPCLINE/>
      <FPCLINE>PERFORM read_picture_bds USING lv_obname &apos;BCOL&apos;</FPCLINE>
      <FPCLINE>                   CHANGING gv_logo_lsa</FPCLINE>
      <FPCLINE>                            lv_retcode.</FPCLINE>
      <FPCLINE>* Anschrift</FPCLINE>
      <FPCLINE>IF NOT es_fp_data-addr_z1 IS INITIAL.</FPCLINE>
      <FPCLINE>  CONCATENATE es_fp_data-addr_z1 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>  INTO gv_anschrift.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>CONCATENATE gv_anschrift es_fp_data-addr_z2 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z3 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z4 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z5 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z6</FPCLINE>
      <FPCLINE>INTO gv_anschrift.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Anschrift Bank</FPCLINE>
      <FPCLINE>IF NOT es_fp_data-bank_addr_z1 IS INITIAL.</FPCLINE>
      <FPCLINE>  CONCATENATE es_fp_data-bank_addr_z1 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>  INTO gv_anschrift_bank.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CONCATENATE gv_anschrift_bank es_fp_data-bank_addr_z2 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-bank_addr_z3 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-bank_addr_z4 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-bank_addr_z5 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-bank_addr_z6</FPCLINE>
      <FPCLINE>INTO gv_anschrift_bank.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>* Verwendungszweck aufbereiten</FPCLINE>
      <FPCLINE/>
      <FPCLINE>CLEAR lv_counter.</FPCLINE>
      <FPCLINE>IF NOT et_febre_orig[] IS INITIAL.</FPCLINE>
      <FPCLINE>  LOOP AT et_febre_orig INTO ls_febre.</FPCLINE>
      <FPCLINE>    ADD 1 TO lv_counter.</FPCLINE>
      <FPCLINE>    CASE lv_counter.</FPCLINE>
      <FPCLINE>      WHEN &apos;1&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw1 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        gv_vzweck = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>      WHEN &apos;2&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw2 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        CONCATENATE gv_vzweck ls_febre-vwezw</FPCLINE>
      <FPCLINE>        INTO gv_vzweck.</FPCLINE>
      <FPCLINE>      WHEN &apos;3&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw3 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        CONCATENATE gv_vzweck ls_febre-vwezw</FPCLINE>
      <FPCLINE>        INTO gv_vzweck.</FPCLINE>
      <FPCLINE>      WHEN &apos;4&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw4 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        CONCATENATE gv_vzweck ls_febre-vwezw</FPCLINE>
      <FPCLINE>        INTO gv_vzweck.</FPCLINE>
      <FPCLINE>    ENDCASE.</FPCLINE>
      <FPCLINE>  ENDLOOP.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  LOOP AT et_febre INTO ls_febre.</FPCLINE>
      <FPCLINE>    ADD 1 TO lv_counter.</FPCLINE>
      <FPCLINE>    CASE lv_counter.</FPCLINE>
      <FPCLINE>      WHEN &apos;1&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw1 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        gv_vzweck = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>      WHEN &apos;2&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw2 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        CONCATENATE gv_vzweck ls_febre-vwezw</FPCLINE>
      <FPCLINE>        INTO gv_vzweck.</FPCLINE>
      <FPCLINE>      WHEN &apos;3&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw3 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        CONCATENATE gv_vzweck ls_febre-vwezw</FPCLINE>
      <FPCLINE>        INTO gv_vzweck.</FPCLINE>
      <FPCLINE>      WHEN &apos;4&apos;.</FPCLINE>
      <FPCLINE>        gs_vzweck-vwezw4 = ls_febre-vwezw.</FPCLINE>
      <FPCLINE>        CONCATENATE gv_vzweck ls_febre-vwezw</FPCLINE>
      <FPCLINE>        INTO gv_vzweck.</FPCLINE>
      <FPCLINE>    ENDCASE.</FPCLINE>
      <FPCLINE>  ENDLOOP.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Betrag in Text Variable übernehmen</FPCLINE>
      <FPCLINE>WRITE es_worklist_fe-kwbtr TO gv_betrag_text CURRENCY es_worklist_fe-kwaer.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>SHIFT gv_betrag_text LEFT DELETING LEADING space.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF es_worklist_fe-kwaer EQ &apos;EUR&apos;.</FPCLINE>
      <FPCLINE>  CONCATENATE gv_betrag_text &apos;€&apos; INTO gv_betrag_text SEPARATED BY space.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  CONCATENATE gv_betrag_text es_worklist_fe-kwaer INTO gv_betrag_text SEPARATED BY space.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Kassenzeichen</FPCLINE>
      <FPCLINE>CASE es_fp_data-formid.</FPCLINE>
      <FPCLINE>  WHEN &apos;510&apos; OR &apos;511&apos; OR &apos;509&apos;.</FPCLINE>
      <FPCLINE>* Kassenzeichen der AO als Referenzkassenzeichen</FPCLINE>
      <FPCLINE>    gv_kassenzeichen = es_fp_data-ao_kasze.</FPCLINE>
      <FPCLINE>  WHEN OTHERS.</FPCLINE>
      <FPCLINE>    gv_kassenzeichen = es_fp_data-kasze.</FPCLINE>
      <FPCLINE>ENDCASE.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Kassenzeichen und Funktionskürzel verbinden</FPCLINE>
      <FPCLINE>IF NOT gs_user_data-function IS INITIAL.</FPCLINE>
      <FPCLINE>  CONCATENATE gv_kassenzeichen &apos;/&apos; gs_user_data-function</FPCLINE>
      <FPCLINE>         INTO gv_kaz_funktion_text.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>* Kassenzeichen mit Funktionstext</FPCLINE>
      <FPCLINE>  gv_kaz_funktion_text = gv_kassenzeichen.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Kombination Belegnummer / Funktion</FPCLINE>
      <FPCLINE>IF NOT es_worklist_fe-belnr IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_beleg_funktion_text = es_worklist_fe-belnr.</FPCLINE>
      <FPCLINE>  SHIFT gv_beleg_funktion_text LEFT DELETING LEADING space.</FPCLINE>
      <FPCLINE>  SHIFT gv_beleg_funktion_text LEFT DELETING LEADING &apos;0&apos;.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  WRITE es_worklist_fe-kukey TO gv_beleg_funktion_text.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  SHIFT gv_beleg_funktion_text LEFT DELETING LEADING space.</FPCLINE>
      <FPCLINE>  SHIFT gv_beleg_funktion_text LEFT DELETING LEADING &apos;0&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  WRITE es_worklist_fe-esnum TO lv_help_text.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  SHIFT lv_help_text LEFT DELETING LEADING space.</FPCLINE>
      <FPCLINE>  SHIFT lv_help_text LEFT DELETING LEADING &apos;0&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Beleg mit Funktionstext</FPCLINE>
      <FPCLINE>  CONCATENATE gv_beleg_funktion_text &apos;/&apos; lv_help_text</FPCLINE>
      <FPCLINE>         INTO gv_beleg_funktion_text.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_belegnr = gv_beleg_funktion_text.</FPCLINE>
      <FPCLINE>gv_belegnr_jahr = es_worklist_fe-gjahr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Belegnummer und Funktionskürzel verbinden</FPCLINE>
      <FPCLINE>IF NOT gs_user_data-function IS INITIAL.</FPCLINE>
      <FPCLINE>  CONCATENATE gv_beleg_funktion_text &apos;/&apos; gs_user_data-function</FPCLINE>
      <FPCLINE>         INTO gv_beleg_funktion_text.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Variante</FPCLINE>
      <FPCLINE>gv_variant  = es_fp_data-variant.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Formular Ausgabeart in extra Feld für Scriptsteuerung</FPCLINE>
      <FPCLINE>gv_formtype = es_fp_data-formtype.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* eigene IBAN --&gt; Zahlungsempfänger</FPCLINE>
      <FPCLINE>gv_iban = es_sender-iban.</FPCLINE>
      <FPCLINE>* korrekter Verwendungszweck</FPCLINE>
      <FPCLINE>gv_vzweck_neu = es_fp_data-vztext.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Fristen als Textfeld</FPCLINE>
      <FPCLINE/>
      <FPCLINE>WRITE es_fp_data-frist   TO gv_frist.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>WRITE es_fp_data-datum   TO gv_datum.</FPCLINE>
      <FPCLINE>WRITE es_fp_data-datum14 TO gv_datum14.</FPCLINE>
      <FPCLINE>WRITE es_fp_data-datum28 TO gv_datum28.</FPCLINE>
      <FPCLINE>WRITE es_fp_data-datum49 TO gv_datum49.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>WRITE es_fp_data-budat   TO gv_budat.</FPCLINE>
      <FPCLINE>WRITE es_fp_data-budat14 TO gv_budat14.</FPCLINE>
      <FPCLINE>WRITE es_fp_data-budat42 TO gv_budat42.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>WRITE es_fp_data-nadat   TO gv_nadat.</FPCLINE>
      <FPCLINE>IF es_fp_data-nadat IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_no_nadat = &apos;X&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>* Eskalationsstufe</FPCLINE>
      <FPCLINE>gv_eskalationsstufe = es_fp_data-status.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Verarbeitungsoption bei Zuvielzahlung</FPCLINE>
      <FPCLINE>gv_zz_option = es_fp_data-/thkr/option.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_einzahler = es_fp_data-ename.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Rücklastschrift</FPCLINE>
      <FPCLINE>WRITE es_fp_data-faellig TO lv_tag.</FPCLINE>
      <FPCLINE>gv_faellig   = lv_tag.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>gv_gesamt_betrag_text = es_fp_data-g_betrag.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_gebuehr = es_fp_data-gebuehr.</FPCLINE>
      <FPCLINE>***</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Faxnummer</FPCLINE>
      <FPCLINE>IF es_fp_data-faxnr IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_no_fax = &apos;X&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Aktenzeichen</FPCLINE>
      <FPCLINE>gv_aktenzeichen = es_fp_data-aktze.</FPCLINE>
      <FPCLINE>IF gv_aktenzeichen IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_no_az = &apos;X&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Bankvermerk</FPCLINE>
      <FPCLINE>gv_bankvermerk = es_fp_data-bankvermerk.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Anzahlungsanordnung</FPCLINE>
      <FPCLINE>gv_ao_ist_betrag    = es_fp_data-ao_ist_betrag_text.</FPCLINE>
      <FPCLINE>gv_ao_soll_betrag   = es_fp_data-ao_soll_betrag_text.</FPCLINE>
      <FPCLINE>gv_ao_kassenzeichen = es_fp_data-ao_kasze.</FPCLINE>
      <FPCLINE>gv_ao_einzahler     = es_fp_data-ao_einzahler.</FPCLINE>
      <FPCLINE>gv_ao_fipex         = es_fp_data-ao_fipex.</FPCLINE>
      <FPCLINE>gv_ao_vom           = es_fp_data-ao_vom.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Datümer aufbereiten</FPCLINE>
      <FPCLINE>IF NOT es_fp_data-ao_faellig IS INITIAL.</FPCLINE>
      <FPCLINE>  WRITE es_fp_data-ao_faellig TO lv_tag.</FPCLINE>
      <FPCLINE>  gv_ao_faellig       = lv_tag.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF NOT es_fp_data-ao_budat IS INITIAL.</FPCLINE>
      <FPCLINE>  WRITE es_fp_data-ao_budat TO lv_tag.</FPCLINE>
      <FPCLINE>  gv_ao_budat       = lv_tag.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Fertigung</FPCLINE>
      <FPCLINE>gv_fertig = es_fp_data-fertig.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Faxnummer Empfänger</FPCLINE>
      <FPCLINE>gv_faxnr = es_fp_data-faxnr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_az_id = es_fp_data-az_id.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*</FPCLINE>
      <FPCLINE>IF es_worklist_fe-paswi IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_no_bic = &apos;X&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* PKH Daten</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Sachbearbeiter PKH</FPCLINE>
      <FPCLINE>IF NOT es_fp_data-pkh_daten-sachbearbeiter IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_sb_name  = es_fp_data-pkh_daten-sachbearbeiter.</FPCLINE>
      <FPCLINE>  gv_sb_telnr = es_fp_data-pkh_daten-sb_telnr.</FPCLINE>
      <FPCLINE>  gv_sb_telfx = es_fp_data-pkh_daten-sb_telfx.</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  gv_sb_name  = gs_user_data-name.</FPCLINE>
      <FPCLINE>  gv_sb_telnr = gs_user_data-tel.</FPCLINE>
      <FPCLINE>  gv_sb_telfx = gs_user_data-fax.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>* Saldo</FPCLINE>
      <FPCLINE>gv_saldo_art = es_fp_data-pkh_daten-saldo_art.</FPCLINE>
      <FPCLINE>* Anzahl Raten</FPCLINE>
      <FPCLINE>gv_anzahl_raten = es_fp_data-pkh_daten-anzahl_raten.</FPCLINE>
      <FPCLINE>*Anzahl faellige Raten</FPCLINE>
      <FPCLINE>gv_anzahl_faellige_raten = es_fp_data-pkh_daten-anzahl_faellige_raten.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>** Mapping Grund der Rücküberweisung:</FPCLINE>
      <FPCLINE>TRY.</FPCLINE>
      <FPCLINE>    gv_grund_rueck = COND #( WHEN es_fp_data-aktze+0(4) = &apos;AC01&apos; THEN &apos;Ungültige IBAN&apos;</FPCLINE>
      <FPCLINE>                             WHEN es_fp_data-aktze+0(4) = &apos;AC04&apos; THEN &apos;Konto aufgelöst&apos;</FPCLINE>
      <FPCLINE>                             WHEN es_fp_data-aktze+0(4) = &apos;AC06&apos; THEN &apos;Konto gesperrt&apos;</FPCLINE>
      <FPCLINE>                             ELSE |Sonstige Gründe ( { es_fp_data-aktze+0(4) } )| ).</FPCLINE>
      <FPCLINE>  CATCH cx_sy_range_out_of_bounds.</FPCLINE>
      <FPCLINE>    gv_grund_rueck = |Sonstige Gründe|.</FPCLINE>
      <FPCLINE>ENDTRY.</FPCLINE>
     </INITIALIZATION>
     <FORMS>
      <FPCLINE>*&amp;---------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>*&amp;      Form  read_picture_bds</FPCLINE>
      <FPCLINE>*&amp;---------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>*       Grafikdatei aus BDS als BMP lesen</FPCLINE>
      <FPCLINE>*----------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>*      CS_PIC_BMP Binärdaten des Bild als BMP</FPCLINE>
      <FPCLINE>*      CV_RETCODE Returncode</FPCLINE>
      <FPCLINE>*----------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>FORM read_picture_bds USING value(iv_obname) TYPE tdobname</FPCLINE>
      <FPCLINE>                            cv_btype   TYPE tdbtype</FPCLINE>
      <FPCLINE>                   CHANGING cv_pic_bmp TYPE xstring</FPCLINE>
      <FPCLINE>                            cv_retcode TYPE sysubrc.</FPCLINE>
      <FPCLINE>                            .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  DATA: lv_object TYPE tdobjectgr,</FPCLINE>
      <FPCLINE>        lv_name   TYPE tdobname,</FPCLINE>
      <FPCLINE>        lv_id     TYPE tdidgr,</FPCLINE>
      <FPCLINE>        lv_btype  TYPE tdbtype.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  CLEAR: cv_pic_bmp.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  lv_object = &apos;GRAPHICS&apos;.</FPCLINE>
      <FPCLINE>  lv_id     = &apos;BMAP&apos;.</FPCLINE>
      <FPCLINE>* lv_btype  = &apos;BMON&apos;.  &quot;(farbige Grafik) für Schwarz-Weiß BMON (Domäne TDBTYPE)</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>* Grafik aus BDS (Transaktion SE78) als BMP lesen</FPCLINE>
      <FPCLINE>  CALL METHOD cl_ssf_xsf_utilities=&gt;get_bds_graphic_as_bmp</FPCLINE>
      <FPCLINE>    EXPORTING</FPCLINE>
      <FPCLINE>      p_object       = lv_object</FPCLINE>
      <FPCLINE>      p_name         = iv_obname</FPCLINE>
      <FPCLINE>      p_id           = lv_id</FPCLINE>
      <FPCLINE>      p_btype        = cv_btype</FPCLINE>
      <FPCLINE>    RECEIVING</FPCLINE>
      <FPCLINE>      p_bmp          = cv_pic_bmp</FPCLINE>
      <FPCLINE>    EXCEPTIONS</FPCLINE>
      <FPCLINE>      not_found      = 1</FPCLINE>
      <FPCLINE>      internal_error = 2</FPCLINE>
      <FPCLINE>      OTHERS         = 3.</FPCLINE>
      <FPCLINE>  cv_retcode = sy-subrc.</FPCLINE>
      <FPCLINE>ENDFORM.                    &quot;read_picture_bds</FPCLINE>
     </FORMS>
    </CL_FP_CODING>
   </cls:CL_FP_CODING>
