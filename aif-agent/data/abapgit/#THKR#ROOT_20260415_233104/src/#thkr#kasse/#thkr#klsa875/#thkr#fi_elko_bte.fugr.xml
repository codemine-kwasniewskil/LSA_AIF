     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;FEBAN: Übergabe von Dynpro&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00002840&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;EVENT&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Allgemeines finden Sie</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>=</TDFORMAT>
       <TDLINE> &lt;DS:DE.EV00002840&gt;hier&lt;/&gt;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Angaben über die Schnittstelle</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Import</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>I_FEBEP         - Einzelsatz des Kontoauszugs. Bei Bedarf kann</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>                  damit (Feld KUKEY) der gesamte Bankdatenspeicher</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>                  gelesen werden. Er darf aber auf keinen Fall</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>                  verändert werden!</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Export</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>E_DYNNR         - Anwendungsdynpro</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>E_REPID         - Programm, das das Dynpro enthält</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Stellt ein Dynpro mit dem Titel &apos;Zusatz&apos; bereit, dass der Anzeige und</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Bearbeitung der kundeneigenen Felder zur Tabelle FEBEP- Einzelposten des</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Elektronischen Kontoauszugs dient. Von diesem Dynpro wird die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Korrespondenzerstellung aufgerufen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;DEPENDENCIES&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Das das Dynpro enthaltende Programm sollte der Übersichtlichkeit halber</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>auch für die anderen Kontoauszugszeitpunkt 2810, 2820 und 2840 zuständig</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>sein. OK-Code-Behandlung (P/S Zeitpunkt 2830) sollte aber auf jeden Fall</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>im gleichen Programm stattfinden.</TDLINE>
      </TLINE>
     </LINES>
    </item>
