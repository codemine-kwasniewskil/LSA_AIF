      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Nachbearbeitung Kontoauszug: Übergabe OK-Code&apos;</TDLINE>
      </TLINE>
