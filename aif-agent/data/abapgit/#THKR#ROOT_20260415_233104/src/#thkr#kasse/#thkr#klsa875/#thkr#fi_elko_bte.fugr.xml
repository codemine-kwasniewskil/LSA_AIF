       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Das Kennzeichen steuert, ob bei einer Ausgabe mit ALV die Drucktasten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>des ALV ein- oder ausgeblendet werden sollen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;RANGE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>0 - Aufruf aus der FEBAN</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>1 - Aufruf aus der FEB_BSPROC, Standard-Drucktasten des ALV unterdrückt</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>2 - Aufruf aus der FEB_BSPROC, Standard-Drucktasten des ALV angezeigt</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;DEFAULT&amp;</TDLINE>
