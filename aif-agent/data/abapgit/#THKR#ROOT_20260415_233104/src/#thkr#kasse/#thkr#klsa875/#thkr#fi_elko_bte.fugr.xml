      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Defaultwert ist 0 (für Transaktion FEBAN). Der aus FEB_BSPROC</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>verwendete Wert wird aus den User-spezifischen Parametern der</TDLINE>
      </TLINE>
      <TLINE>
