     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/FI_BTE_PROCESS_00107050</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00002</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;RFFMKG03: Anordnung ändern&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00107050&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;PROCESS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Dieser Prozess wird im Programm RFFMKG03 (Erzeuge Anordnungen aus</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Anzahlungen auf Mittelvormerkungen) aufgerufen, bevor eine Anordnung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>verbucht wird.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Rahmen des Prozesses können Sie die Anordnung mit Zusatzdaten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>anreichern oder bereits vorbelegte Feldinhalte verändern.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>An den Prozess werden</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Nummer der Mittelreservierung (I_BELNR),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Postion der Mittelreservierung (I_BLPOS),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Belegpositionsentwicklung der Mittelreservierung (I_BPENT),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>der Belegkopf der Anzahlung (I_BKPF),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Belegzeilen der Anzahlung (T_BSEG),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die CPD-Daten der Anzahlung, falls vorhanden (T_BSEC) und</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Steuerdaten der Anzahlung, falls vorhanden (T_BSET)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>übergeben.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Für die Buchung der Anordnung sind darüber hinaus</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>der Belegkopf (T_BBKPF),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Belegzeilen (T_BBSEG) und</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Steuerinformationen (T_BBTAX)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>mit den bereits vorhandenen Daten gefüllt. Die Daten dieser drei</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Tabellen können Sie in diesem Business Transaction Event verändern.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Anschluss an den Aufruf dieses Business Transaction Events wird die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Anordnung über das Direct-Input-Verfahren analog zum Programm RFBIBLK0</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(Übernahme von Anordnungen aus Vorverfahren) verbucht.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Weitere Informationen zum Aufbau und Füllen der Tabellen T_BBKPF,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>T_BBSEG und T_BBTAX entnehmen Sie der Programmdokumentation des</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Programms &lt;DS:RE.RFBIBLK0&gt;RFBIBLK0&lt;/&gt;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
