   <cls:CL_FP_CODING id="o5">
    <CL_FP_INTERFACE_DATA_CHANGED classVersion="1">
     <INTERFACE_DATA href="#o1"/>
    </CL_FP_INTERFACE_DATA_CHANGED>
    <CL_FP_CODING classVersion="1">
     <INPUT_PARAMETERS>
      <FPPARAMETER>MHNK</FPPARAMETER>
     </INPUT_PARAMETERS>
     <OUTPUT_PARAMETERS/>
     <INITIALIZATION>
      <FPCLINE>CASE mhnk-smaber . &quot;Mahnbereich</FPCLINE>
      <FPCLINE>  WHEN &apos;P1&apos; OR &apos;P2&apos; OR &apos;P3&apos; OR &apos;P4&apos; OR &apos;M7&apos;.</FPCLINE>
      <FPCLINE>    doc_type = &apos;Zahlungserinnerung&apos;.</FPCLINE>
      <FPCLINE>  WHEN OTHERS.</FPCLINE>
      <FPCLINE>    doc_type = &apos;Mahnung&apos;.</FPCLINE>
      <FPCLINE>ENDCASE.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>*TRY. &quot; Get missing fields:</FPCLINE>
      <FPCLINE>&quot;** We can use the firsr</FPCLINE>
      <FPCLINE>LOOP AT th_mhnd INTO DATA(mahn) WHERE blart CP &apos;D*&apos; AND blart &lt;&gt; &apos;DZ&apos;.</FPCLINE>
      <FPCLINE>  EXIT.</FPCLINE>
      <FPCLINE>ENDLOOP.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF mahn IS NOT INITIAL.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  &quot;&quot; Get Soll-Betrag der Forderung + SOLL</FPCLINE>
      <FPCLINE>  &quot;&quot; Get Text für alle Belege</FPCLINE>
      <FPCLINE>  LOOP AT th_mhnd INTO DATA(line) WHERE blart &lt;&gt; &apos;DZ&apos;.</FPCLINE>
      <FPCLINE>    sollbetrag += line-dmshb.</FPCLINE>
      <FPCLINE>    SELECT FROM bseg</FPCLINE>
      <FPCLINE>     FIELDS sgtxt AS key,</FPCLINE>
      <FPCLINE>            CAST( @line-dmshb AS CHAR ) AS value</FPCLINE>
      <FPCLINE>     WHERE bukrs EQ @line-bukrs</FPCLINE>
      <FPCLINE>       AND belnr EQ @line-belnr</FPCLINE>
      <FPCLINE>       AND gjahr EQ @line-gjahr</FPCLINE>
      <FPCLINE>       AND bschl EQ &apos;50&apos;</FPCLINE>
      <FPCLINE>     APPENDING TABLE @beleg_liste.</FPCLINE>
      <FPCLINE>  ENDLOOP.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  &quot;&quot; Get all Gezahlt and adjust Soll-Betrag</FPCLINE>
      <FPCLINE>  LOOP AT th_mhnd INTO line WHERE blart = &apos;DZ&apos;.</FPCLINE>
      <FPCLINE>    gezahlt += abs( line-dmshb ).</FPCLINE>
      <FPCLINE>  ENDLOOP.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  kassz = mahn-xblnr.</FPCLINE>
      <FPCLINE>  faedt = mahn-faedt.</FPCLINE>
      <FPCLINE>  gsber = mahn-gsber.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  &quot;** Get one line for OM</FPCLINE>
      <FPCLINE>  SELECT SINGLE FROM bkpf AS h INNER JOIN bseg AS i ON i~bukrs = h~bukrs</FPCLINE>
      <FPCLINE>                                              AND i~belnr = h~belnr</FPCLINE>
      <FPCLINE>                                              AND i~gjahr = h~gjahr</FPCLINE>
      <FPCLINE>     FIELDS h~psofn,</FPCLINE>
      <FPCLINE>            i~fistl,</FPCLINE>
      <FPCLINE>            i~kostl</FPCLINE>
      <FPCLINE>     WHERE h~bukrs EQ @mahn-bukrs</FPCLINE>
      <FPCLINE>       AND h~belnr EQ @mahn-belnr</FPCLINE>
      <FPCLINE>       AND h~gjahr EQ @mahn-gjahr</FPCLINE>
      <FPCLINE>       AND i~bschl EQ &apos;50&apos;</FPCLINE>
      <FPCLINE>     INTO @DATA(blbseg).</FPCLINE>
      <FPCLINE>  aktenzeichen  = blbseg-psofn.</FPCLINE>
      <FPCLINE>  fistl         = blbseg-fistl.</FPCLINE>
      <FPCLINE>  DATA(kostl)   = blbseg-kostl.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>** Get address for DST:</FPCLINE>
      <FPCLINE>DATA(add_att) = VALUE zom_addr_attr( zpgsbr = gsber acc_fcentr = fistl zkostl = kostl ).</FPCLINE>
      <FPCLINE>DATA(add_out) = VALUE zom_addr_out( ).</FPCLINE>
      <FPCLINE>CALL FUNCTION &apos;Z_OM_FIND_ADDRESS&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    is_addr_attr = add_att</FPCLINE>
      <FPCLINE>  IMPORTING</FPCLINE>
      <FPCLINE>    es_addr_out  = add_out</FPCLINE>
      <FPCLINE>  EXCEPTIONS</FPCLINE>
      <FPCLINE>    OTHERS       = 1.</FPCLINE>
      <FPCLINE>IF sy-subrc = 0.</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( add_out-line0 ) ).</FPCLINE>
      <FPCLINE>  IF NOT add_out-ressort_txt_2 = &apos;&apos;.</FPCLINE>
      <FPCLINE>    adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( add_out-ressort_txt_2 ) ).</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( add_out-line1 ) ).</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( add_out-line2 ) ).</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( |Telefon: { add_out-telnr }| ) ).</FPCLINE>
      <FPCLINE>ELSE.</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( &apos;Keine DST Adresse gefunden&apos; ) ).</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( &apos;&lt;Fehler&gt;&apos; ) ).</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( &apos;&lt;Fehler&gt;&apos; ) ).</FPCLINE>
      <FPCLINE>  adresse_anfor_dst = VALUE #( BASE  adresse_anfor_dst ( |Telefon: &lt;Fehler&gt;| ) ).</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>** Generate QR Code:</FPCLINE>
      <FPCLINE/>
      <FPCLINE>** Verzugszinsen berechnen</FPCLINE>
      <FPCLINE>TRY.</FPCLINE>
      <FPCLINE>    verzug = t_sumtab[ 1 ]-wzsbt.</FPCLINE>
      <FPCLINE>    IF verzug IS INITIAL.</FPCLINE>
      <FPCLINE>      SELECT SINGLE FROM bseg</FPCLINE>
      <FPCLINE>        FIELDS wrbtr AS betrag</FPCLINE>
      <FPCLINE>       WHERE bukrs EQ @mahn-bukrs</FPCLINE>
      <FPCLINE>         AND gjahr EQ @mahn-gjahr</FPCLINE>
      <FPCLINE>         AND koart EQ &apos;D&apos;</FPCLINE>
      <FPCLINE>         AND h_blart EQ &apos;SG&apos;</FPCLINE>
      <FPCLINE>         AND rebzg EQ @mahn-belnr</FPCLINE>
      <FPCLINE>       INTO @verzug.</FPCLINE>
      <FPCLINE>    ENDIF.</FPCLINE>
      <FPCLINE>  CATCH cx_sy_itab_line_not_found .</FPCLINE>
      <FPCLINE>    &quot; nothing to do here</FPCLINE>
      <FPCLINE>ENDTRY.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>DATA total TYPE wrbtr.</FPCLINE>
      <FPCLINE>total = sollbetrag + verzug + f150d-mhngf - gezahlt .</FPCLINE>
      <FPCLINE>qrcode = NEW /thkr/cl_epc_qrcode_generator(</FPCLINE>
      <FPCLINE>  iban             = &apos;DE21810000000081001500&apos;           &quot; IBAN (International Bank Account Number)</FPCLINE>
      <FPCLINE>  bic              = &apos;MARKDEF1810&apos;                      &quot; BIC Code</FPCLINE>
      <FPCLINE>  value            = total                &quot; Betrag in Belegwährung</FPCLINE>
      <FPCLINE>  reference        = CONV char20( kassz )               &quot; Verwendungszweck</FPCLINE>
      <FPCLINE>  receiver_name    = &apos;Landeshauptkasse Sachsen-Anhalt&apos;  &quot; Name des Empfängers</FPCLINE>
      <FPCLINE>  reference_prefix = &apos;QR: &apos;                             &quot; Prefix für Verwendungszweck</FPCLINE>
      <FPCLINE>                     )-&gt;get_qrcode_as_xstring( ).</FPCLINE>
     </INITIALIZATION>
