<?xfa generator="AdobeLiveCycleDesigner_V11.0.9.20240424.1.48_SAP" APIVersion="3.6.24095.0"?><xdp:xdp xmlns:xdp="http://ns.adobe.com/xdp/" timeStamp="2025-03-31T06:11:57Z" uuid="8be5c498-dc3a-4048-8ab3-2f78b0c1343d">
<template xmlns:xliff="urn:oasis:names:tc:xliff:document:1.1" xmlns="http://www.xfa.org/schema/xfa-template/2.8/">
   <tags xmlns="http://www.xfa.org/schema/xfa-xliff/1.0/"><value id="N1006">Our account with you</value><value id="N1111">Postings are included upto and including</value><value id="N1116"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4348.0"><p>Postings are included up to<span style="xfa-spacerun:yes">   </span></p><p>and including</p></body></value><value id="N169"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p><span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField009333" xfa:embedMode="raw" xfa:embedType="uri"/><span style="xfa-spacerun:yes">    </span><span style="font-size:10pt">Dunning</span></p></body></value><value id="N2105">Street</value><value id="N2177">Pincode</value><value id="N2249">City</value><value id="N297">Text Field</value><value id="N3011">Text Field</value><value id="N3030">#</value><value id="N3039">Current Page</value><value id="N3094">Text Field</value><value id="N3113">##</value><value id="N3122">Total Number of pages</value><value id="N3143"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p>
                    Page
                    <span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField027835" xfa:embedMode="raw" xfa:embedType="uri"/>
                    of
                    <span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField009033" xfa:embedMode="raw" xfa:embedType="uri"/></p></body></value><value id="N3191">Page Number</value><value id="N334"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p>Sample Print out</p></body></value><value id="N3413"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="tab-interval:0.393in;tab-stops:left 1.377in">Dear Sir/Madam,</p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">The invoices listed below are due for payment. If you have paid the amounts due in the intervening period, please disregard this letter.</p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p></body></value><value id="N3510"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="tab-interval:0.393in;tab-stops:left 1.377in">Dear Sir/Madam,</p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">We have already sent you a reminder about the due date of our invoices. We have, however, so far been unable to find any record of incoming payment for these invoices.</p><p style="tab-interval:0.393in;tab-stops:left 1.377in">Please transfer these overdue amounts immediately. If this dunning notice once again fails to elicit any action on your part, we will unfortunately have no option but to calculate interest on arrears.</p></body></value><value id="N3561">LOGO</value><value id="N363">Sample Print out</value><value id="N3641">Debit interest rate</value><value id="N3710">Date/Time Field</value><value id="N3720">Target date</value><value id="N3797">Currency</value><value id="N3870">Total due itemsin dunning currency from dunning level</value><value id="N3891"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="tab-interval:0.393in;tab-stops:left 1.377in">Dear Sir/Madam,</p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">
                        Since you have not reacted to our previous dunning notices, we have had to calculate interest on arrears to the amount of
                        <span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField003164" xfa:embedMode="raw" xfa:embedType="uri"/>
                        %.
                        <span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">
                        For the items due, as well as for the interest on arrears, we are now giving you a final payment period up until
                        <span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField008488" xfa:embedMode="raw" xfa:embedType="uri"/>
                        . If you do not adhere to this payment deadline, we will unfortunately have to apply for a court order for our receivables to the amount of
                        <span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField005945" xfa:embedMode="raw" xfa:embedType="uri"/><span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField018521" xfa:embedMode="raw" xfa:embedType="uri"/>
                        .
                        <span style="xfa-spacerun:yes">  </span></p></body></value><value id="N4066">Debit interest rate</value><value id="N4135">Date/Time Field</value><value id="N4145">Target date</value><value id="N4222">Currency</value><value id="N4295">Total due itemsin dunning currency from dunning level</value><value id="N4316"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="tab-interval:0.393in;tab-stops:left 1.377in">Dear Sir/Madam,</p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">
                        Since you have not reacted to our previous dunning notices, we have had to calculate interest on arrears to the amount of
                        <span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField022666" xfa:embedMode="raw" xfa:embedType="uri"/>
                        %.
                        <span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">
                        For the items due, as well as for the interest on arrears, we are now giving you a final payment period up until
                        <span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField008926" xfa:embedMode="raw" xfa:embedType="uri"/>
                        .
                        <span style="xfa-spacerun:yes">  </span>
                        If you do not adhere to this payment deadline, we will unfortunately have to apply for a court order for our receivables to the amount of
                        <span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField011689" xfa:embedMode="raw" xfa:embedType="uri"/><span style="xfa-spacerun:yes">  </span><span xfa:embed="#floatingField001892" xfa:embedMode="raw" xfa:embedType="uri"/>
                        .
                        <span style="xfa-spacerun:yes"> </span></p></body></value><value id="N4512"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="tab-interval:0.393in;tab-stops:left 1.377in;font-weight:bold">For internal purposes only</p><p style="tab-interval:0.393in;tab-stops:left 1.377in"><span style="xfa-spacerun:yes"> </span></p><p style="tab-interval:0.393in;tab-stops:left 1.377in">Since the last dunning run, there has been movement in the account of the business partner against whom a legal dunning procedure has</p><p style="tab-interval:0.393in;tab-stops:left 1.377in">
                        Date of legal dunning procedure:
                        <span style="xfa-spacerun:yes"> </span><span xfa:embed="#floatingField021504" xfa:embedMode="raw" xfa:embedType="uri"/></p></body></value><value id="N4638">Text Field</value><value id="N4754"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p><span style="xfa-spacerun:yes"> </span></p><p><span style="xfa-spacerun:yes"> </span></p></body></value><value id="N4825"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="tab-interval:0.393in;tab-stops:left 1.377in">List of items</p></body></value><value id="N49">LOGO</value><value id="N492">Date</value><value id="N4951">Document</value><value id="N4973">Document</value><value id="N4994">Date</value><value id="N5016">Date</value><value id="N5051">Currency</value><value id="N5058">Currency</value><value id="N5085">Amount</value><value id="N5108">Amount</value><value id="N5129">Due</value><value id="N515">Date</value><value id="N5151">Due</value><value id="N5172">Arrears</value><value id="N5194">Arrears</value><value id="N5215">DL</value><value id="N5238">DL</value><value id="N5268">Interest</value><value id="N5291">Interest</value><value id="N5432">Long text</value><value id="N5511">Long Text</value><value id="N5574">Accounting Document Number</value><value id="N5654">Document Date</value><value id="N5725">Currency Key</value><value id="N577">Our Clerk</value><value id="N5805">Amount</value><value id="N5884">Due Date</value><value id="N5963">Days in Arrears by Net due date</value><value id="N598">Clerk First Name</value><value id="N6035">Dunning Level</value><value id="N6122">Interest Amount</value><value id="N6210">Text</value><value id="N6267"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p style="font-size:10pt">
                      Dunning Charge
                      <span style="font-family:'Courier New'"><span style="xfa-spacerun:yes"> </span></span><span style="xfa-spacerun:yes"> </span><span style="font-size:12pt"><span style="xfa-spacerun:yes">             </span></span></p></body></value><value id="N6388">Currency </value><value id="N6465">Amount</value><value id="N6497">Line</value><value id="N6500">Line</value><value id="N664">Last Name</value><value id="N6853">Account balance</value><value id="N6943">Currency</value><value id="N7020">Amount</value><value id="N7073"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="1.4.4065.0"><p>Account balance</p></body></value><value id="N7161">Total of due items</value><value id="N7162">Currency</value><value id="N7239">Amount</value><value id="N726">Telephone</value><value id="N747">Telephone</value><value id="N809">Fax</value><value id="N830">Fax</value><value id="N923">Your Account with us</value><value id="N935"><body xmlns="http://www.w3.org/1999/xhtml" xmlns:xfa="http://www.xfa.org/schema/xfa-data/1.0/" xmlns:xft-xliff="http://www.xfa.org/schema/xfa-xliff/1.0/" xfa:APIVersion="2.3.5062.0"><p style="font-family:Arial;font-size:8pt">Your Account with us</p></body></value><value id="N985">Our account with you</value></tags>
