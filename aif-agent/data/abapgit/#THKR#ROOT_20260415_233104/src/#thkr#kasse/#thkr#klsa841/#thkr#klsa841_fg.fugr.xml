    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>/THKR/KLSA841_BTE_00103020</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0002</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00018</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/KLSA841_BTE_00103020</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00002</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Mahnzinsen buchen&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00103020&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>PROCESS</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Prozeß wird sowohl im Mahnprogramm als auch im Report RFFMINTCALC</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(Verzinsung von ausgeglichenen Belegen) aufgerufen, bevor Mahnzinsen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>verbucht werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Rahmen des Prozesses kann der zu buchende Mahnzinsbeleg mit</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Zusatzdaten angereichert werden, bzw. es können bereits vorbelegte</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Feldinhalte verändert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>An den Prozess werden</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Mahnposition (I_F_MHND),</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>der Mahnkopf (I_F_MHNK) sowie</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die IS-PS-Zusatzdaten zum Mahnverfahren (I_F_PSKW4)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>übergeben. Die für die Buchung des Belegs benötigten Tabellen T_BBKPF,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>T_BBSEG und T_BBTAX sind bereits mit den vorhandenen Daten gefüllt und</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>können in diesem Prozess verändert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>/THKR/KLSA841_BTE_00103020</OBJECT>
      <LANGU>E</LANGU>
      <TYP>T</TYP>
      <VERSION>0002</VERSION>
      <TXTLINES>00018</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/KLSA841_BTE_00103020</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>E</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00002</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Post Dunning Interest&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00103020&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>PROCESS</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>This process is called in the dunning program and in program</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>RFFMINTCALC (interest calculation for cleared documents) before the</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>posting of dunning interest.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In this process, supplementary data can be added to the dunning</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>interest documents you want to post and you can make changes to fields</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>that have predefined entries.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The following are transferred to the process:</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>Dunning line item (I_F_MHND)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>Dunning document header (I_F_MHNK)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>Additional IS-PS data on dunning procedure (I_F_PSKW4)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The tables required for the posting of the document (tables T_BBKPF,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>T_BBSEG and T_BBTAX) already contain the existing data and can be</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>changed during this process.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
