     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Mahnen: Ändern der Parameter vor der Selektion&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001703&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;INTERFACE&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Zeitpunkt wird aus dem Programm SAPF150S2 aufgerufen, vor der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Selektion der Posten. Es besteht die Möglichkeit, die Parameter des</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Mahnlaufs (Buchungskreise, Debitoren, Kreditoren, freie Abgrenzungen,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Konten für Zusatzprotokoll) zu verändern.</TDLINE>
      </TLINE>
     </LINES>
    </item>
