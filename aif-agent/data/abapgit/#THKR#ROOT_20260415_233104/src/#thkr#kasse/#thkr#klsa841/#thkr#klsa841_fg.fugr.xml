       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>die Mahnpositionen (T_MHND)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>sowie die IS-PS-Zusatzdaten zum Mahnverfahren (I_F_PSKW4)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>übergeben. Die für die Buchung des Belegs benötigten Tabellen T_BBKPF,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>T_BBSEG und T_BBTAX sind bereits mit den vorhandenen Daten gefüllt und</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>können in diesem Prozess verändert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>/THKR/KLSA841_BTE_00103025</OBJECT>
      <LANGU>E</LANGU>
      <TYP>T</TYP>
      <VERSION>0002</VERSION>
      <TXTLINES>00017</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/KLSA841_BTE_00103025</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>E</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00002</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Post Dunning Charges&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00103025&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>PROCESS</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>This process is called during the dunning program before the posting of</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>dunning charges.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In this process, supplementary data can be added to the dunning charge</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>documents you want to post and you can make changes to fields that have</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>predefined entries.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The following data is transferred to the process:</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>Dunning header (I_F_MHNK)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>Dunning line items (T_MHND)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>B1</TDFORMAT>
       <TDLINE>Additional IS-PS data on dunning procedure (I_F_PSKW4)</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The tables required for the posting of the document (tables T_BBKPF,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>T_BBSEG and T_BBTAX) already contain the existing data and can be</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>changed during this process.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS__-THKR_-KLSA841_BTE_00103025>
   <LONGTEXTS__-THKR_-KLSA841_BTE_00107040>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>/THKR/KLSA841_BTE_00107040</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0006</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00039</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/KLSA841_BTE_00107040</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00006</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp; = &apos;Substitution von Feldern in den Anordnungen&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00107040&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp; = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>Prozeß</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Prozess wird bei der Sicherung von Anordnungen durchlaufen. Auf</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>diese Weise ist sichergestellt, dass die Zuweisung der neuen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Feldinhalte erst dann erfolgt, wenn die Bearbeitung der Anordnung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>abgeschlossen ist.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>*</TDFORMAT>
       <TDLINE>Mit diesem Prozess können Sie den Anordnungen beispielsweise</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>organisationsinterne Nummern zuweisen, die den Geschäftsvorfall</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>identifizieren.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>Schnittstelle</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Beim Speichern werden in der Tabelle U_T_PSO02 die Kopf- und</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Personendaten einer Anordnung übergeben. Bei der Verrechnungsanordnung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>sind in der Tabelle U_T_PSO02 nur die Kopfdaten enthalten. Die Tabelle</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>U_T_PSO02S enthält in beiden Fällen die Sachkontenzeilen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In diesem Prozess dürfen jedoch &lt;ZH&gt;nicht&lt;/&gt; alle Felder geändert</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>werden. Sie dürfen nur die in den Strukturen PSO02_SUBST (für Kopf- und</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Personendaten) und PSO02S_SUBST (Sachkontendaten) aufgeführten Felder</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>füllen bzw. ändern, da für diese Felder keine speziellen Prüfungen in</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>den Anordnungen notwendig sind. Bei den Kopf- und Personendaten darf</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>also nur die Tabelle C_T_PSO02_SUBST geändert werden. Änderungen an den</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Sachkonten sind auf der Tabelle C_T_PSO02S_SUBST durchzuführen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Zusammenhang zwischen der Tabelle U_T_PSO02 d.h. den Kopf- und</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Personenkontendaten und der Tabelle U_T_PSO02S d.h. den Sachkontendaten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>wird über das Feld &lt;ZH&gt;ITABKEY&lt;/&gt; hergestellt.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>&lt;ZH&gt;Wichtig&lt;/&gt;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die in den Strukturen PSO02_SUBST und PSO02S_SUBST enthaltenen Felder</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>&lt;ZH&gt;ITABKEY&lt;/&gt; und &lt;ZH&gt;BZKEY&lt;/&gt; werden zur internen Verwaltung der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Anordnungszeilen benötigt. Sie dürfen nicht verändert werden. Auch</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>sollten Sie keine Sortierung der Sachkontenzeilen vornehmen, da sonst</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>eine Übernahme der Änderungen nicht durchgeführt werden kann.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Wenn Sie in diesem Prozess eine Feldänderung durchgeführt haben, müssen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Sie den Parameter E_FLG_CHANGE setzen. Dann werden die Änderungen in</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>die Anordnung übernommen. Wenn dieser Parameter nicht gesetzt ist, wird</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>nicht geprüft, ob Sie Änderungen durchgeführt haben. Dies dient der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Zeitersparnis, falls der Prozess nicht verwendet wird, bzw. wenn der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>von Ihnen angelegte Baustein mehrmals ohne Änderung durchlaufen wird.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FURTHER_SOURCES_OF_INF&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS__-THKR_-KLSA841_BTE_00107040>
