*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: /THKR/KASSZ_KETV................................*
FORM GET_DATA_/THKR/KASSZ_KETV.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM /THKR/KASSZ_KETT WHERE
(VIM_WHERETAB) .
    CLEAR /THKR/KASSZ_KETV .
/THKR/KASSZ_KETV-MANDT =
/THKR/KASSZ_KETT-MANDT .
/THKR/KASSZ_KETV-FKASSZ =
/THKR/KASSZ_KETT-FKASSZ .
/THKR/KASSZ_KETV-WKASSZ =
/THKR/KASSZ_KETT-WKASSZ .
/THKR/KASSZ_KETV-ID =
/THKR/KASSZ_KETT-ID .
<VIM_TOTAL_STRUC> = /THKR/KASSZ_KETV.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/KASSZ_KETV .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/KASSZ_KETV.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/KASSZ_KETV-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/KASSZ_KETT WHERE
  ID = /THKR/KASSZ_KETV-ID AND
  FKASSZ = /THKR/KASSZ_KETV-FKASSZ AND
  WKASSZ = /THKR/KASSZ_KETV-WKASSZ .
    IF SY-SUBRC = 0.
    DELETE /THKR/KASSZ_KETT .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/KASSZ_KETT WHERE
  ID = /THKR/KASSZ_KETV-ID AND
  FKASSZ = /THKR/KASSZ_KETV-FKASSZ AND
  WKASSZ = /THKR/KASSZ_KETV-WKASSZ .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/KASSZ_KETT.
    ENDIF.
/THKR/KASSZ_KETT-MANDT =
/THKR/KASSZ_KETV-MANDT .
/THKR/KASSZ_KETT-FKASSZ =
/THKR/KASSZ_KETV-FKASSZ .
/THKR/KASSZ_KETT-WKASSZ =
/THKR/KASSZ_KETV-WKASSZ .
/THKR/KASSZ_KETT-ID =
/THKR/KASSZ_KETV-ID .
    IF SY-SUBRC = 0.
    UPDATE /THKR/KASSZ_KETT ##WARN_OK.
    ELSE.
    INSERT /THKR/KASSZ_KETT .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/KASSZ_KETV-UPD_FLAG,
STATUS_/THKR/KASSZ_KETV-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
*---------------------------------------------------------------------*
FORM READ_SINGLE_/THKR/KASSZ_KETV.
  SELECT SINGLE * FROM /THKR/KASSZ_KETT WHERE
ID = /THKR/KASSZ_KETV-ID AND
FKASSZ = /THKR/KASSZ_KETV-FKASSZ AND
WKASSZ = /THKR/KASSZ_KETV-WKASSZ .
/THKR/KASSZ_KETV-MANDT =
/THKR/KASSZ_KETT-MANDT .
/THKR/KASSZ_KETV-FKASSZ =
/THKR/KASSZ_KETT-FKASSZ .
/THKR/KASSZ_KETV-WKASSZ =
/THKR/KASSZ_KETT-WKASSZ .
/THKR/KASSZ_KETV-ID =
/THKR/KASSZ_KETT-ID .
ENDFORM.
*---------------------------------------------------------------------*
FORM CORR_MAINT_/THKR/KASSZ_KETV USING VALUE(CM_ACTION) RC.
  DATA: RETCODE LIKE SY-SUBRC, COUNT TYPE I, TRSP_KEYLEN TYPE SYFLENG.
  FIELD-SYMBOLS: <TAB_KEY_X> TYPE X.
  CLEAR RC.
MOVE /THKR/KASSZ_KETV-ID TO
/THKR/KASSZ_KETT-ID .
MOVE /THKR/KASSZ_KETV-FKASSZ TO
/THKR/KASSZ_KETT-FKASSZ .
MOVE /THKR/KASSZ_KETV-WKASSZ TO
/THKR/KASSZ_KETT-WKASSZ .
MOVE /THKR/KASSZ_KETV-MANDT TO
/THKR/KASSZ_KETT-MANDT .
  CORR_KEYTAB             =  E071K.
  CORR_KEYTAB-OBJNAME     = '/THKR/KASSZ_KETT'.
  IF NOT <vim_corr_keyx> IS ASSIGNED.
    ASSIGN CORR_KEYTAB-TABKEY TO <vim_corr_keyx> CASTING.
  ENDIF.
  ASSIGN /THKR/KASSZ_KETT TO <TAB_KEY_X> CASTING.
  PERFORM VIM_GET_TRSPKEYLEN
    USING '/THKR/KASSZ_KETT'
    CHANGING TRSP_KEYLEN.
  <VIM_CORR_KEYX>(TRSP_KEYLEN) = <TAB_KEY_X>(TRSP_KEYLEN).
  PERFORM UPDATE_CORR_KEYTAB USING CM_ACTION RETCODE.
  ADD: RETCODE TO RC, 1 TO COUNT.
  IF RC LT COUNT AND CM_ACTION NE PRUEFEN.
    CLEAR RC.
  ENDIF.

ENDFORM.
