      <FPPARAMETER>GV_MONAT</FPPARAMETER>
      <FPPARAMETER>GV_DATUM</FPPARAMETER>
      <FPPARAMETER>GV_HAUSHALTSJAHR</FPPARAMETER>
      <FPPARAMETER>GV_GESAMTBETRAG</FPPARAMETER>
      <FPPARAMETER>GV_DUPLIKAT</FPPARAMETER>
