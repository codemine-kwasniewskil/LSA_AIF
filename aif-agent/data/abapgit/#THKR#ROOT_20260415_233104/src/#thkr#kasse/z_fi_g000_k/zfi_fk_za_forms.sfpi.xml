      <FPPARAMETER>GV_STATUS_TXT</FPPARAMETER>
      <FPPARAMETER>GV_TYPE_TXT</FPPARAMETER>
     </OUTPUT_PARAMETERS>
     <INITIALIZATION>
      <FPCLINE>DATA: lt_tel       TYPE TABLE OF bapiadtel,</FPCLINE>
      <FPCLINE>      ls_tel       TYPE bapiadtel,</FPCLINE>
      <FPCLINE>      lt_fax       TYPE TABLE OF bapiadfax,</FPCLINE>
      <FPCLINE>      ls_fax       TYPE bapiadfax,</FPCLINE>
      <FPCLINE>      lt_return    TYPE TABLE OF bapiret2,</FPCLINE>
      <FPCLINE>      ls_febre     TYPE febre,</FPCLINE>
      <FPCLINE>      lv_counter   TYPE i,</FPCLINE>
      <FPCLINE>      lv_obname    TYPE tdobname,</FPCLINE>
      <FPCLINE>      ls_address   TYPE bapiaddr3,</FPCLINE>
      <FPCLINE>      lv_pic_bmp   TYPE xstring,</FPCLINE>
      <FPCLINE>      lv_help_text TYPE char5,</FPCLINE>
      <FPCLINE>      lv_retcode   TYPE sysubrc.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Benutzerdaten lesen</FPCLINE>
      <FPCLINE>CALL FUNCTION &apos;BAPI_USER_GET_DETAIL&apos;</FPCLINE>
      <FPCLINE>  EXPORTING</FPCLINE>
      <FPCLINE>    username = sy-uname</FPCLINE>
      <FPCLINE>  IMPORTING</FPCLINE>
      <FPCLINE>    address  = ls_address</FPCLINE>
      <FPCLINE>  TABLES</FPCLINE>
      <FPCLINE>    return   = lt_return.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF NOT ls_address IS INITIAL.</FPCLINE>
      <FPCLINE>* Telefon</FPCLINE>
      <FPCLINE>  IF NOT ls_address-tel1_ext IS INITIAL.</FPCLINE>
      <FPCLINE>    CONCATENATE ls_address-tel1_numbr &apos;-&apos; ls_address-tel1_ext INTO gs_user_data-tel.</FPCLINE>
      <FPCLINE>  ELSE.</FPCLINE>
      <FPCLINE>    MOVE ls_address-tel1_numbr TO gs_user_data-tel.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>* Fax</FPCLINE>
      <FPCLINE>  IF NOT ls_address-fax_extens IS INITIAL.</FPCLINE>
      <FPCLINE>    CONCATENATE ls_address-fax_number &apos;-&apos; ls_address-fax_extens INTO gs_user_data-fax.</FPCLINE>
      <FPCLINE>  ELSE.</FPCLINE>
      <FPCLINE>    MOVE ls_address-fax_number TO gs_user_data-fax.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>* Nachname</FPCLINE>
      <FPCLINE>  IF NOT ls_address-title_p IS INITIAL.</FPCLINE>
      <FPCLINE>    CONCATENATE ls_address-title_p ls_address-lastname</FPCLINE>
      <FPCLINE>    INTO gs_user_data-name SEPARATED BY space.</FPCLINE>
      <FPCLINE>  ELSE.</FPCLINE>
      <FPCLINE>    MOVE ls_address-lastname TO gs_user_data-name.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>* Funktion - Bereich und Kennung</FPCLINE>
      <FPCLINE>  MOVE ls_address-function TO gs_user_data-function.</FPCLINE>
      <FPCLINE>  MOVE ls_address-function TO gv_funktion.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Ort</FPCLINE>
      <FPCLINE>  MOVE ls_address-city TO gs_user_data-ort.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Sachbearbeiter</FPCLINE>
      <FPCLINE>IF NOT es_fp_data-sachbearbeiter IS INITIAL.</FPCLINE>
      <FPCLINE>  gv_bearbeiter = es_fp_data-sachbearbeiter.</FPCLINE>
      <FPCLINE>ELSEIF es_fp_data-duplikat EQ &apos;X&apos;.</FPCLINE>
      <FPCLINE>  MOVE gs_user_data-name TO gv_bearbeiter.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Verbindungen Sachbearbeiter</FPCLINE>
      <FPCLINE>gv_sb_telnr = es_fp_data-sb_telnr.</FPCLINE>
      <FPCLINE>gv_sb_telfx = es_fp_data-sb_telfx.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF es_fp_data-duplikat EQ &apos;X&apos;.</FPCLINE>
      <FPCLINE>  IF gv_sb_telnr IS INITIAL.</FPCLINE>
      <FPCLINE>    gv_sb_telnr = ls_address-tel1_numbr.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  IF gv_sb_telfx IS INITIAL.</FPCLINE>
      <FPCLINE>    gv_sb_telfx = ls_address-fax_number.</FPCLINE>
      <FPCLINE>  ENDIF.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>lv_obname = &apos;Z_LBW_WAPPEN_KLEIN&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>PERFORM read_picture_bds USING lv_obname &apos;BCOL&apos;</FPCLINE>
      <FPCLINE>                   CHANGING gv_logo_lbw</FPCLINE>
      <FPCLINE>                            lv_retcode.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>lv_obname = &apos;Z_LBW_LOEWE&apos;.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>PERFORM read_picture_bds USING lv_obname &apos;BMON&apos;</FPCLINE>
      <FPCLINE>                   CHANGING gv_logo_loewe</FPCLINE>
      <FPCLINE>                            lv_retcode.</FPCLINE>
      <FPCLINE>* Variante</FPCLINE>
      <FPCLINE>gv_variant       = es_fp_data-variant.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Anschrift</FPCLINE>
      <FPCLINE>CONCATENATE es_fp_data-addr_z1 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z2 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z3 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z4 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z5 cl_abap_char_utilities=&gt;newline</FPCLINE>
      <FPCLINE>            es_fp_data-addr_z6</FPCLINE>
      <FPCLINE>INTO gv_anschrift.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Haushaltsjahr</FPCLINE>
      <FPCLINE>gv_haushaltsjahr = es_fp_data-hhjahr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Kassenzeichen</FPCLINE>
      <FPCLINE>gv_kassenzeichen = es_fp_data-kassenzeichen.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Datum</FPCLINE>
      <FPCLINE>gv_datum = es_fp_data-tagesdatum.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Währungscode</FPCLINE>
      <FPCLINE>gv_waers = es_fp_data-waers.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Duplikat</FPCLINE>
      <FPCLINE>gv_duplikat = es_fp_data-duplikat.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_gesamtbetrag =  es_fp_data-betrag.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>&quot;** Check if it&apos;s &quot;DRAFT&quot;</FPCLINE>
      <FPCLINE>IF es_fp_data-duplikat = abap_true.</FPCLINE>
      <FPCLINE>  gv_status_txt = &apos;Probedruck&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE>&quot;** Check if it&apos;s &quot;COPIED&quot;</FPCLINE>
      <FPCLINE>IF es_fp_data-already_sent = abap_true.</FPCLINE>
      <FPCLINE>  gv_status_txt = &apos;Kopie&apos;.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>&quot;** Set Header Text</FPCLINE>
      <FPCLINE>gv_type_txt = &apos;Einzahlung auf eine Annahmeanordnung&apos;.</FPCLINE>
      <FPCLINE>if es_fp_data-fehlernummer = 210.</FPCLINE>
      <FPCLINE>  gv_type_txt = &apos;Stornierung der Einzahlung auf eine Annahmeanordnung&apos;.</FPCLINE>
      <FPCLINE>endif.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_saldo_art = es_fp_data-saldo_art.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_anzahl_raten = es_fp_data-anzahl_raten.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>gv_anzahl_faellige_raten = es_fp_data-anzahl_faellige_raten.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Dateiname</FPCLINE>
      <FPCLINE>gv_dateiname = es_fp_data-dateiname.</FPCLINE>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE/>
      <FPCLINE>* IBAN und BIC</FPCLINE>
      <FPCLINE>gv_iban_bic = es_fp_data-iban.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF NOT es_fp_data-bic IS INITIAL.</FPCLINE>
      <FPCLINE>  CONCATENATE gv_iban_bic &apos;/&apos; es_fp_data-bic INTO</FPCLINE>
      <FPCLINE>    gv_iban_bic SEPARATED BY space.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>* Kontonummer und BLZ</FPCLINE>
      <FPCLINE>gv_kto_blz = es_fp_data-konto_nr.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>IF NOT es_fp_data-blz IS INITIAL.</FPCLINE>
      <FPCLINE>  CONCATENATE gv_kto_blz &apos;/&apos; es_fp_data-blz INTO</FPCLINE>
      <FPCLINE>    gv_kto_blz SEPARATED BY space.</FPCLINE>
      <FPCLINE>ENDIF.</FPCLINE>
     </INITIALIZATION>
     <FORMS>
      <FPCLINE>*&amp;---------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>*&amp;      Form  read_picture_bds</FPCLINE>
      <FPCLINE>*&amp;---------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>*       Grafikdatei aus BDS als BMP lesen</FPCLINE>
      <FPCLINE>*----------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>*      CS_PIC_BMP Binärdaten des Bild als BMP</FPCLINE>
      <FPCLINE>*      CV_RETCODE Returncode</FPCLINE>
      <FPCLINE>*----------------------------------------------------------------------*</FPCLINE>
      <FPCLINE>FORM read_picture_bds USING value(iv_obname) TYPE tdobname</FPCLINE>
      <FPCLINE>                            cv_btype   TYPE tdbtype</FPCLINE>
      <FPCLINE>                   CHANGING cv_pic_bmp TYPE xstring</FPCLINE>
      <FPCLINE>                            cv_retcode TYPE sysubrc.</FPCLINE>
      <FPCLINE>                            .</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  DATA: lv_object TYPE tdobjectgr,</FPCLINE>
      <FPCLINE>        lv_name   TYPE tdobname,</FPCLINE>
      <FPCLINE>        lv_id     TYPE tdidgr,</FPCLINE>
      <FPCLINE>        lv_btype  TYPE tdbtype.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  CLEAR: cv_pic_bmp.</FPCLINE>
      <FPCLINE/>
      <FPCLINE>  lv_object = &apos;GRAPHICS&apos;.</FPCLINE>
      <FPCLINE>  lv_id     = &apos;BMAP&apos;.</FPCLINE>
      <FPCLINE>* lv_btype  = &apos;BMON&apos;.  &quot;(farbige Grafik) für Schwarz-Weiß BMON (Domäne TDBTYPE)</FPCLINE>
