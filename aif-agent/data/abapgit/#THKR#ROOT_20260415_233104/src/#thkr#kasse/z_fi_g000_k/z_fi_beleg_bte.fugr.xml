     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>Z_FI_BTE_AU_0000940</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00018</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp; = &apos;Prüfung beim Verlassen der OP-Bearbeitung&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00000940&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;INTERFACE&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Zeitpunkt wird beim Verlassen der OP-Bearbeitung z.B. Buchen oder</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Simulieren durchlaufen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>SCHNITTSTELLE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Schnittstelle entspricht der des Zeitpunkts 00000920. Zusätzlich</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>enthält die Schnittstelle die Exception &apos;Cancel&apos;. Wird diese Exception</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ausgelöst, kann die OP-Bearbeitung nicht verlassen werden.</TDLINE>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS_Z_FI_BTE_AU_0000940>
   <LONGTEXTS_Z_FI_BTE_AU_0001120>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>Z_FI_BTE_AU_0001120</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0012</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00029</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>Z_FI_BTE_AU_0001120</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00012</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Substitution Belegfelder&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001120&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>PROCESS</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Prozess wird immer dann erreicht, wenn vor dem Verbuchen eines</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Beleges sämtliche Schlußprüfungen abgeschlossen sind. Zu diesem</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Zeitpunkt ist die Belegnummer jedoch noch nicht vergeben.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>SCHNITTSTELLE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>An die Zusatzkomponente werden (nur für Informationszwecke) die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>aktuellen Belegköpfe (mehr als einer z.B. bei</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>buchungskreisübergreifenden Vorgängen), die korrespondierenden</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Belegzeilen sowie die Dauerbuchungsdaten zum Belegkopf und die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>CPD-Daten übergeben. Diese Daten dürfen nicht bearbeitet werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Stattdessen werden zwei weitere Tabellen (T_BKPFSUB, T_BSEGSUB) und die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Struktur BKDF_SUBSTübergeben. Diese sind gefüllt mit den Inhalten der</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Felder, die substituierbar sind. Das Feld TABIX enthält eine</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Zeilennummer, die anzeigt aus welcher Zeile in T_BSEG bzw. T_BKPF die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Feldinhalte stammen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Zu beachten: Nach der Substitution erfolgt keine weitere Prüfung. Eine</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>bestehende Zahlsperre, z.B. auf Grund einer Workflowdefinition, darf</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>nicht überschrieben werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In der 2. Zeile der Tabelle T_BSEG soll der Feldinhalt von SGTXT</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(Positionstext) mit dem Inhalt &apos;TEST&apos; substituiert werden. Das</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>erfordert im wesentlichen eine Anweisungsfolge der Form</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>READ TABLE T_BSEGSUB WITH KEY TABIX = 2.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>T_BSEGSUB-SGTXT = &apos;TEST&apos;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>MODIFY T_BSEGSUB INDEX SY-TABIX.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Diese Anweisungsfolge ist im eigenen Baustein zu codieren !!</TDLINE>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>Z_FI_BTE_AU_0001120</OBJECT>
      <LANGU>E</LANGU>
      <TYP>T</TYP>
      <VERSION>0012</VERSION>
      <TXTLINES>00028</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>Z_FI_BTE_AU_0001120</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>E</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00012</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Substitution document fields&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001120&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;PROCESS&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX LANGUAGE EN</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>PROCESS</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>This process is always reached when all the final checks have been</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>completed before a document is updated. However, at this stage, the</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>document number has not yet been assigned.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>INTERFACE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The current document headers (there will be more than one for</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>cross-company code transactions, for example), the corresponding line</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>items and the recurring entry data for the document header and the</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>one-time account data are transferred to the additional component, for</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>information purposes only. You must not edit this data. Instead, two</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>additional tables (T_BKPFSUB and T_BSEGSUB) and the structure BKDF_SUBST</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>are also transferred. The contents of the fields that can be substituted</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>are entered in these tables. Field TABIX contains a line number which</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>shows from which line in T_BSEG or T_BKPF the field contents originate.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Note: There is no additional check after the substitution. You must not</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>overwrite an existing payment lock (for example, due to a workflow</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>definition).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>In the second line of table T_BSEG, the field contents from SGTXT (item</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>text) should be replaced by the entry &apos;TEST&apos;. This basically requires a</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>statement sequence in the form</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>READ TABLE T_BSEGSUB WITH KEY TABIX = 2.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>T_BSEGSUB-SGTXT = &apos;TEST&apos;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>MODIFY T_BSEGSUB INDEX SY-TABIX.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>You must code this statement sequence in your own function module.</TDLINE>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS_Z_FI_BTE_AU_0001120>
   <LONGTEXTS_Z_FI_BTE_EV_0001025>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>Z_FI_BTE_EV_0001025</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0009</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00016</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>Z_FI_BTE_EV_0001025</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00009</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Beleg buchen, Validierung der Daten&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001025&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;INTERFACE&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Zeitpunkt liegt nach allen Prüfungen des gesamten Beleges und noch</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>vor der Nummernvergabe. Nach diesem Zeitpunkt dürfen keine Errormessages</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>mehr gesendet werden. Der Beleg ist an dieser Stelle fertig und kann vor</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>der Verbuchung nicht mehr geändert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es wird die Eingangszahlsperre E überprüft - es darf kein Ausgleich</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>erfolgen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>SCHNITTSTELLE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>An die Zusatzkomponente werden alle aktuellen und für die Verbuchung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>relevanten Belegdaten sowie diverse Steuerparameter übergeben. Es können</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>an dieser Stelle noch eigene Prüfungen auf die aktuellen Belegdaten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>implementiert werden.</TDLINE>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>Z_FI_BTE_EV_0001025</OBJECT>
      <LANGU>E</LANGU>
      <TYP>T</TYP>
      <VERSION>0007</VERSION>
      <TXTLINES>00014</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>Z_FI_BTE_EV_0001025</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>E</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00007</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Document posting, data validation&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001025&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;INTERFACE&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX LANGUAGE EN</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>This Event lies following all checks on the whole document, but prior</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>to number assignment. Following this Event, no further error messages</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>may be sent. The document is complete at this point, and no further</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>changes can be made to it prior to posting.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>INTERFACE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>All current data, all document data relevant for the posting, and</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>various control parameters are transferred to the additional component.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>At this point you can still implement your own checks on the current</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>document data.</TDLINE>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS_Z_FI_BTE_EV_0001025>
  </asx:values>
 </asx:abap>
