      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Document posting, update posting&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001030&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;INTERFACE&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX LANGUAGE EN</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>This Event is reached prior to the update posting module for FI</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(POST_DOCUMENT) and also following callup of the interface part.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>INTERFACE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>All current data, all document data required for the update, and</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>various control parameters are transferred to the additional component.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>The indicator I_XVBUP is used for information purposes only - that the</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>SAP standard system carries out an update posting asynchronously.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>HU</TDFORMAT>
       <TDLINE>It follows that no database activities involving the writing of data</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>may be carried out in the additional component.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The update posting (including tables specific to Add-ons) are carried</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>out by the COMMIT WORK of the standard process. If your function module</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>is not accessed via RFC, you should always initiate asynchronous update</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>posting using the ABAP statement:</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>PE</TDFORMAT>
       <TDLINE>IN UPDATE TASK.</TDLINE>
      </TLINE>
     </LINES>
    </item>
