     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TEXT&amp;  = &apos;Beleg buchen, Verbuchung&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;EVENT&amp; = &apos;00001030&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>DEFINE &amp;TYPE&amp;  = &apos;INTERFACE&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/:</TDFORMAT>
       <TDLINE>INCLUDE FI_OPEN_FI_DOCUMENTATION_1 OBJECT DOKU ID TX</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>EVENT</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Zeitpunkt liegt hinter dem Aufruf des Verbuchers fürs FI</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>(POST_DOCUMENT) und auch nach dem Aufruf des Interface-Anteils.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>SCHNITTSTELLE</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es werden Sätze für die Tabelle &lt;ZH&gt;ZFI_BN_NACHRICHT &lt;/&gt;der Herkunft Y -</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Zahlungsanzeige vorbereitet.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>An die Zusatzkomponente werden alle aktuellen und für die Verbuchung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>relevanten Belegdaten sowie diverse Steuerparameter übergeben. Das</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Kennzeichen I_XVBUP dient als reine Information, daß der SAP-Standard</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>asynchron verbucht.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>HU</TDFORMAT>
       <TDLINE>Damit darf in der Zusatzkomponente keine schreibende Datenbankaktion</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ausgeführt werden !!</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Die Verbuchung (auch der Add-On-spezifischen Tabellen) wird durch den</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>COMMIT WORK des Standardablaufes ausgeführt. Falls Ihr Funktionsbaustein</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>nicht über RFC gerufen wird, veranlassen Sie stets asynchrone Verbuchung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>mit dem Zusatz</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>PE</TDFORMAT>
       <TDLINE>IN UPDATE TASK.</TDLINE>
      </TLINE>
     </LINES>
    </item>
