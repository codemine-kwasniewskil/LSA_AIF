      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Dieses Programm selektiert die Bankenstämme gemäß der angegebenen</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Selektion und ändert dann die Bankengruppierung des Bankenstamms. Es</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>werden nur Bankenstämme selektiert, die keine Löschvormerkung haben und</TDLINE>
      </TLINE>
