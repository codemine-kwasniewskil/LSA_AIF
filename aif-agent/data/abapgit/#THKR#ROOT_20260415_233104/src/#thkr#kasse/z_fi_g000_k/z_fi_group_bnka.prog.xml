      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Gruppierung wird wie folgt erstellt.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE> Es wird die 4 Stelle des Feldes Bankschlüssel genommen und dann in das</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Feld Gruppierung geschrieben.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>     0 = 00, 1 = 01, 2 = 02, 4 = 04, 5 = 05, 6 = 06, 7 = 07, 8 = 08, 9 =</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>09.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>  Für den Bankschlüssel  &apos;60050101 wird 02 gesetzt.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE> Bankschlüssel die an der 4. Stelle eine 3 stehen haben werden nicht</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>geändert und daher auch nicht ausgewiesen.</TDLINE>
