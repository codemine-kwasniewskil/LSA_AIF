*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: Z_MAINT_PAYAC01.................................*
FORM GET_DATA_Z_MAINT_PAYAC01.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM PAYAC01 WHERE
(VIM_WHERETAB) .
    CLEAR Z_MAINT_PAYAC01 .
Z_MAINT_PAYAC01-MANDT =
PAYAC01-MANDT .
Z_MAINT_PAYAC01-GJHID =
PAYAC01-GJHID .
Z_MAINT_PAYAC01-BUKFM =
PAYAC01-BUKFM .
Z_MAINT_PAYAC01-ACIND =
PAYAC01-ACIND .
Z_MAINT_PAYAC01-FIPEX =
PAYAC01-FIPEX .
Z_MAINT_PAYAC01-GEBER =
PAYAC01-GEBER .
Z_MAINT_PAYAC01-BUDGET_PD =
PAYAC01-BUDGET_PD .
Z_MAINT_PAYAC01-FISTL =
PAYAC01-FISTL .
Z_MAINT_PAYAC01-PSOTY =
PAYAC01-PSOTY .
Z_MAINT_PAYAC01-FKBER =
PAYAC01-FKBER .
<VIM_TOTAL_STRUC> = Z_MAINT_PAYAC01.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_Z_MAINT_PAYAC01 .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO Z_MAINT_PAYAC01.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_Z_MAINT_PAYAC01-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM PAYAC01 WHERE
  GJHID = Z_MAINT_PAYAC01-GJHID AND
  BUKFM = Z_MAINT_PAYAC01-BUKFM AND
  ACIND = Z_MAINT_PAYAC01-ACIND AND
  FIPEX = Z_MAINT_PAYAC01-FIPEX AND
  GEBER = Z_MAINT_PAYAC01-GEBER AND
  BUDGET_PD = Z_MAINT_PAYAC01-BUDGET_PD AND
  FISTL = Z_MAINT_PAYAC01-FISTL AND
  PSOTY = Z_MAINT_PAYAC01-PSOTY AND
  FKBER = Z_MAINT_PAYAC01-FKBER .
    IF SY-SUBRC = 0.
    DELETE PAYAC01 .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM PAYAC01 WHERE
  GJHID = Z_MAINT_PAYAC01-GJHID AND
  BUKFM = Z_MAINT_PAYAC01-BUKFM AND
  ACIND = Z_MAINT_PAYAC01-ACIND AND
  FIPEX = Z_MAINT_PAYAC01-FIPEX AND
  GEBER = Z_MAINT_PAYAC01-GEBER AND
  BUDGET_PD = Z_MAINT_PAYAC01-BUDGET_PD AND
  FISTL = Z_MAINT_PAYAC01-FISTL AND
  PSOTY = Z_MAINT_PAYAC01-PSOTY AND
  FKBER = Z_MAINT_PAYAC01-FKBER .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR PAYAC01.
    ENDIF.
PAYAC01-MANDT =
Z_MAINT_PAYAC01-MANDT .
PAYAC01-GJHID =
Z_MAINT_PAYAC01-GJHID .
PAYAC01-BUKFM =
Z_MAINT_PAYAC01-BUKFM .
PAYAC01-ACIND =
Z_MAINT_PAYAC01-ACIND .
PAYAC01-FIPEX =
Z_MAINT_PAYAC01-FIPEX .
PAYAC01-GEBER =
Z_MAINT_PAYAC01-GEBER .
PAYAC01-BUDGET_PD =
Z_MAINT_PAYAC01-BUDGET_PD .
PAYAC01-FISTL =
Z_MAINT_PAYAC01-FISTL .
PAYAC01-PSOTY =
Z_MAINT_PAYAC01-PSOTY .
PAYAC01-FKBER =
Z_MAINT_PAYAC01-FKBER .
    IF SY-SUBRC = 0.
    UPDATE PAYAC01 ##WARN_OK.
    ELSE.
    INSERT PAYAC01 .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_Z_MAINT_PAYAC01-UPD_FLAG,
STATUS_Z_MAINT_PAYAC01-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
