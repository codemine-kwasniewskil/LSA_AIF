      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/WF_REGEL_AO_01</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00006</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FUNCTIONALITY&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Der Funktionsbaustein RH_GET_STRUCTURE liest aus dem Container</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ac_container die Containerelemente &apos;PLVAR&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>                                   &apos;OR_AGENT&apos; bzw. &apos;OTYPE&apos; und &apos;OBJID&apos;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>                             sowie &apos;TDEPTH&apos;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>Das Containerelement &apos;OR_AGENT&apos; ist eine Verkettung der Elemente</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>&apos;OTYPE&apos; und &apos;OBJID&apos;.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>/</TDFORMAT>
       <TDLINE>Die Tabelle actor_tab enthält die Treffermenge der Bearbeiter, die aus</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>den selektierten Containerelementen und einer strukturellen Auswertung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>resultieren.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Es werden die Bearbeiter einer Workflow-Aufgabe gesucht. Der Container</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>ac_container enthält die Elemente, die den Aufgabentyp, sowie dessen Id</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>und die Planvariante beschreiben. In der Tabelle actor_tab werden alle</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>möglichen Bearbeiter zurückgegeben. Unter Bearbeiter versteht man</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Objekte mit organisatorischen Aspekten.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FURTHER_SOURCES_OF_INF&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
   </LONGTEXTS__-THKR_-WF_REGEL_AO_01>
