   <LONGTEXTS__-THKR_-WF_AORD_CREATE_VIA_EVENT>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>/THKR/WF_AORD_CREATE_VIA_EVENT</OBJECT>
      <LANGU>D</LANGU>
      <TYP>T</TYP>
      <VERSION>0008</VERSION>
      <MASTERLANG>X</MASTERLANG>
      <TXTLINES>00016</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/WF_AORD_CREATE_VIA_EVENT</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>D</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00008</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FUNCTIONALITY&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Dieser Funktionsbaustein erzeugt aus einem Ereignis ein Workitem</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>beliebigen Typs. Der Typ ergibt sich aus der Art der Aufgabe. Die</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>zugrundeliegende Aufgabe muß mit dem Parameter RECTYPE übergeben</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Im Funktionsbaustein wird der Datenfluß vom Ereigniscontainer auf den</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>benötigten Workitem-Container durchgeführt. Dieser Datenfluß muß bei</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>der Aufgabe definiert worden sein. Dieser Datenfluß stellt die einzige</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Möglichkeit dar, den Workitem-Container mit Daten zu versorgen.</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Sämtliche übrigen für das Erzeugen des Workitems benötigten Parameter</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>können nur die beim Workitem (bzw. der Aufgabe) vereinbarten</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Defaultwerte haben (z.B. Regeln für Bearbeiter, Priorität,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Callback-Bausteine, Deadline Behandlung etc.).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>Falls ein solcher Datenfluß nicht definiert ist, wird das entsprechende</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Workitem auch nicht erzeugt. Die dann auszuführende Fehlerbehandlung</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>kann in der Administration zur Ereignis-Queue auf der Registerkarte</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>Grunddaten definiert werden.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FURTHER_SOURCES_OF_INF&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
    <item>
     <DOKIL>
      <ID>FU</ID>
      <OBJECT>/THKR/WF_AORD_CREATE_VIA_EVENT</OBJECT>
      <LANGU>E</LANGU>
      <TYP>T</TYP>
      <VERSION>0008</VERSION>
      <TXTLINES>00013</TXTLINES>
      <DOKSTATE>A</DOKSTATE>
     </DOKIL>
     <HEAD>
      <TDOBJECT>DOKU</TDOBJECT>
      <TDNAME>/THKR/WF_AORD_CREATE_VIA_EVENT</TDNAME>
      <TDID>FU</TDID>
      <TDSPRAS>E</TDSPRAS>
      <TDFORM>S_DOCU_SHOW</TDFORM>
      <TDSTYLE>S_DOCUS1</TDSTYLE>
      <TDVERSION>00008</TDVERSION>
      <TDLINESIZE>072</TDLINESIZE>
     </HEAD>
     <LINES>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FUNCTIONALITY&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>This function module creates a work item from an event. The type is</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>derived from the type of the task. The underlying task must be passed</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>with the parameter RECTYPE.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>The binding from the event container to the required work item</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>container is completed in the function module. This binding must have</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>been defined for the task, and is the only way of providing the work</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>item container with data. All other parameters required to create the</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>work item can only have the default values declared for the work item</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>or task (for example, rules for agents, priority, callback modules,</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>deadline handling).</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
       <TDLINE>If no binding of this kind is defined, the relevant work item is not</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>created. Error handing can be defined on the tab page Basic data in</TDLINE>
      </TLINE>
      <TLINE>
       <TDLINE>event queue adminstration.</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;EXAMPLE&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;HINTS&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
      <TLINE>
       <TDFORMAT>U1</TDFORMAT>
       <TDLINE>&amp;FURTHER_SOURCES_OF_INF&amp;</TDLINE>
      </TLINE>
      <TLINE>
       <TDFORMAT>AS</TDFORMAT>
      </TLINE>
     </LINES>
    </item>
