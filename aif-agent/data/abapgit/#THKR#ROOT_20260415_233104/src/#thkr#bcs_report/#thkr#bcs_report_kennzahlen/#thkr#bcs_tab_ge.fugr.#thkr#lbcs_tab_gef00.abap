  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/KF_REPT_03-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/KF_REPTERM WHERE
  KEYFIG = /THKR/KF_REPT_03-KEYFIG AND
  DATASOURCE = /THKR/KF_REPT_03-DATASOURCE AND
  TERMNUM = /THKR/KF_REPT_03-TERMNUM .
    IF SY-SUBRC = 0.
    DELETE /THKR/KF_REPTERM .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/KF_REPTERM WHERE
  KEYFIG = /THKR/KF_REPT_03-KEYFIG AND
  DATASOURCE = /THKR/KF_REPT_03-DATASOURCE AND
  TERMNUM = /THKR/KF_REPT_03-TERMNUM .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/KF_REPTERM.
    ENDIF.
/THKR/KF_REPTERM-CLIENT =
/THKR/KF_REPT_03-CLIENT .
/THKR/KF_REPTERM-KEYFIG =
/THKR/KF_REPT_03-KEYFIG .
/THKR/KF_REPTERM-DATASOURCE =
/THKR/KF_REPT_03-DATASOURCE .
/THKR/KF_REPTERM-TERMNUM =
/THKR/KF_REPT_03-TERMNUM .
/THKR/KF_REPTERM-SIGN =
/THKR/KF_REPT_03-SIGN .
/THKR/KF_REPTERM-RLDNR =
/THKR/KF_REPT_03-RLDNR .
/THKR/KF_REPTERM-RVERS =
/THKR/KF_REPT_03-RVERS .
/THKR/KF_REPTERM-RYEAR =
/THKR/KF_REPT_03-RYEAR .
/THKR/KF_REPTERM-PERIO =
/THKR/KF_REPT_03-PERIO .
/THKR/KF_REPTERM-CEFFYEAR_9 =
/THKR/KF_REPT_03-CEFFYEAR_9 .
/THKR/KF_REPTERM-VALTYPE_9 =
/THKR/KF_REPT_03-VALTYPE_9 .
/THKR/KF_REPTERM-WFSTATE_9 =
/THKR/KF_REPT_03-WFSTATE_9 .
/THKR/KF_REPTERM-PROCESS_9 =
/THKR/KF_REPT_03-PROCESS_9 .
/THKR/KF_REPTERM-BUDTYPE_9 =
/THKR/KF_REPT_03-BUDTYPE_9 .
    IF SY-SUBRC = 0.
    UPDATE /THKR/KF_REPTERM ##WARN_OK.
    ELSE.
    INSERT /THKR/KF_REPTERM .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/KF_REPT_03-UPD_FLAG,
STATUS_/THKR/KF_REPT_03-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
