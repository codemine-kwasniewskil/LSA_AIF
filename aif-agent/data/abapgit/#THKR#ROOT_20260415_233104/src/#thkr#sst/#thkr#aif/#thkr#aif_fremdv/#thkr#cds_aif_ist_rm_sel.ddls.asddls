@AbapCatalog.viewEnhancementCategory: [#NONE]
@AccessControl.authorizationCheck: #NOT_REQUIRED
@EndUserText.label: 'Cube Rückmeldung'
@Metadata.ignorePropagatedAnnotations: false
@ObjectModel.usageType:{
    serviceQuality: #X,
    sizeCategory: #S,
    dataClass: #MIXED
}
define view entity /THKR/CDS_AIF_IST_RM_SEL
  as select from /THKR/CDS_AIF_IST_RM_CUBE as cube
  association [0..1] to /THKR/CDS_AIF_IST_RM_IBAN as _iban on  _iban.belnr = cube.augbl
                                                           and _iban.bukrs = cube.bukrs
                                                           and _iban.gjahr = cube.auggj
{
      //  key stunr,
  key fikrs,
      //      FinancialManagementAreaName,
      Fipos,
      //      CommitmentItemDescription,
      Fistel,
      //      FundsCenterDescription,
      bukrs,
      //      ControllingAreaName,
      kapitel,
      titel,
      hhj,
      max( cast( zhldt as abap.int4 ) ) as buchungsdatum,
      zhldt, // For search only
      Kassenzeichen,
      lotkz,
      AccountingDocumentType,
      BelegSstKey,
      min( knbelnr )                    as belnr,
      //      bsegsi_belnr,
      //      bsegan_belnr,
      kngjahr,
      //    knbuzei,
      //      wrttp,
      AccountingDocCreatedByUser,
      twaer,
      psofn,
      bktxt,
      kassendatum,
      //      btart,
      valutadatum,
      bvtyp,
      Zeitbuchnummer,
      AlreadySent,
      @Semantics.amount.currencyCode : 'twaer'
      sum(sollOriginalbetrag)           as Original,
      @Semantics.amount.currencyCode : 'twaer'
      sum(gezahlt)                      as Gezahlt,
      @Semantics.amount.currencyCode : 'twaer'
      sum(offenesSoll)                  as Soll,
      auggj,
      augbl,
      Einzahldatum,
      erledigt,
      aktenzeichen,
      dienstelle,
      wrbtr,
      bpname,
      bpid,
      bpadresse,
      bphousenumber,
      bpplz,
      bpcity,
      BPcountrycode,
      _iban._febep.piban                as iban,
      _iban._febep.paswi                as SWIFT,
      _iban._febep.partn                as einzahler,
      _iban._febep.sgtxt                as verwendungszweck,
      //      iban,
      //      bic,
      //      bankname,
      SstKey,
      /* Associations */
      _CI,
      _CoCo,
      //      _CVT,
      _FC,
      _FMA,
      _FYFFMA,
      _iban
}
group by
// stunr,
  fikrs,
  //      FinancialManagementAreaName,
  Fipos,
  //      CommitmentItemDescription,
  Fistel,
  //      FundsCenterDescription,
  bukrs,
  //      ControllingAreaName,
  kapitel,
  titel,
  hhj,
  //      zhldt,
  Kassenzeichen,
  lotkz,
  AccountingDocumentType,
  BelegSstKey,
  //      BelegSstKey,
  //      knbelnr,
  //      bsegsi_belnr,
  //      bsegan_belnr,
  kngjahr,
  //      knbuzei,
  //      wrttp,
  AccountingDocCreatedByUser,
  twaer,
  psofn,
  kassendatum,
  //      btart,
  valutadatum,
  bvtyp,
  Zeitbuchnummer,
  AlreadySent,
  auggj,
  augbl,
  Einzahldatum,
  erledigt,
  aktenzeichen,
  dienstelle,
  wrbtr,
  bpname,
  bpid,
  bpadresse,
  bphousenumber,
  bpplz,
  bpcity,
  BPcountrycode,
  _iban._febep.piban,
  _iban._febep.paswi,
  _iban._febep.partn,
  _iban._febep.sgtxt,
  bktxt,
  SstKey,
  zhldt
