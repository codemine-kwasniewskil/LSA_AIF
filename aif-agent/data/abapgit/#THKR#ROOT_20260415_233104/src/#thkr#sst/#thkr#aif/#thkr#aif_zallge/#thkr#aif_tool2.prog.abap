*&---------------------------------------------------------------------*
*& Report /THKR/AIF_TOOL
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
REPORT /thkr/aif_tool2 LINE-SIZE 255.
*&---------------------------------------------------------------------*
PARAMETERS: ak_test AS CHECKBOX.
*&---------------------------------------------------------------------*
DATA ls_bkpf TYPE bkpf.
*&---------------------------------------------------------------------*
SELECT * FROM bkpf INTO ls_bkpf
  WHERE bukrs = 'R030'
    AND belnr = '6000000006'.

  WRITE: /1 ls_bkpf-belnr, ls_bkpf-bktxt.
  ls_bkpf-bktxt = '3600-E80374-3'.
  MODIFY bkpf FROM ls_bkpf.
ENDSELECT.
*&---------------------------------------------------------------------*
