*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/VFV_PR_ART .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/VFV_PR_ART.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/VFV_PR_ART-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/CFV_PR_ART WHERE
  FREMDVERF = /THKR/VFV_PR_ART-FREMDVERF AND
  PROCESS_TYPE = /THKR/VFV_PR_ART-PROCESS_TYPE .
    IF SY-SUBRC = 0.
    DELETE /THKR/CFV_PR_ART .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/CFV_PR_ART WHERE
  FREMDVERF = /THKR/VFV_PR_ART-FREMDVERF AND
  PROCESS_TYPE = /THKR/VFV_PR_ART-PROCESS_TYPE .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/CFV_PR_ART.
    ENDIF.
/THKR/CFV_PR_ART-MANDT =
/THKR/VFV_PR_ART-MANDT .
/THKR/CFV_PR_ART-FREMDVERF =
/THKR/VFV_PR_ART-FREMDVERF .
/THKR/CFV_PR_ART-PROCESS_TYPE =
/THKR/VFV_PR_ART-PROCESS_TYPE .
/THKR/CFV_PR_ART-DE_FORMAT =
/THKR/VFV_PR_ART-DE_FORMAT .
/THKR/CFV_PR_ART-DE_CONVERSION =
/THKR/VFV_PR_ART-DE_CONVERSION .
/THKR/CFV_PR_ART-DE_XSLT =
/THKR/VFV_PR_ART-DE_XSLT .
/THKR/CFV_PR_ART-GI_ID_PARTNER =
/THKR/VFV_PR_ART-GI_ID_PARTNER .
/THKR/CFV_PR_ART-GI_ID_PARTNER2 =
/THKR/VFV_PR_ART-GI_ID_PARTNER2 .
/THKR/CFV_PR_ART-GI_ID_PSM_AO =
/THKR/VFV_PR_ART-GI_ID_PSM_AO .
/THKR/CFV_PR_ART-GI_ID_PSM_AO2 =
/THKR/VFV_PR_ART-GI_ID_PSM_AO2 .
    IF SY-SUBRC = 0.
    UPDATE /THKR/CFV_PR_ART ##WARN_OK.
    ELSE.
    INSERT /THKR/CFV_PR_ART .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/VFV_PR_ART-UPD_FLAG,
STATUS_/THKR/VFV_PR_ART-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
