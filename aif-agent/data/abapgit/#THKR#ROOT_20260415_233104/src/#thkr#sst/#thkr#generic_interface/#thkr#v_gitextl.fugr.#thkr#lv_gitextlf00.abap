*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: /THKR/V_GITEXTL.................................*
FORM GET_DATA_/THKR/V_GITEXTL.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM /THKR/C_GITEXTL WHERE
(VIM_WHERETAB) .
    CLEAR /THKR/V_GITEXTL .
/THKR/V_GITEXTL-MANDT =
/THKR/C_GITEXTL-MANDT .
/THKR/V_GITEXTL-TEXT_ID =
/THKR/C_GITEXTL-TEXT_ID .
/THKR/V_GITEXTL-LINE_NR =
/THKR/C_GITEXTL-LINE_NR .
/THKR/V_GITEXTL-LF =
/THKR/C_GITEXTL-LF .
/THKR/V_GITEXTL-TEXT_LINE =
/THKR/C_GITEXTL-TEXT_LINE .
    SELECT SINGLE * FROM /THKR/C_GI_TEXT WHERE
TEXT_ID = /THKR/C_GITEXTL-TEXT_ID .
    IF SY-SUBRC EQ 0.
    ENDIF.
<VIM_TOTAL_STRUC> = /THKR/V_GITEXTL.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_GITEXTL .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_GITEXTL.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_GITEXTL-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GITEXTL WHERE
  TEXT_ID = /THKR/V_GITEXTL-TEXT_ID AND
  LINE_NR = /THKR/V_GITEXTL-LINE_NR .
    IF SY-SUBRC = 0.
    DELETE /THKR/C_GITEXTL .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GITEXTL WHERE
  TEXT_ID = /THKR/V_GITEXTL-TEXT_ID AND
  LINE_NR = /THKR/V_GITEXTL-LINE_NR .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/C_GITEXTL.
    ENDIF.
/THKR/C_GITEXTL-MANDT =
/THKR/V_GITEXTL-MANDT .
/THKR/C_GITEXTL-TEXT_ID =
/THKR/V_GITEXTL-TEXT_ID .
/THKR/C_GITEXTL-LINE_NR =
/THKR/V_GITEXTL-LINE_NR .
/THKR/C_GITEXTL-LF =
/THKR/V_GITEXTL-LF .
/THKR/C_GITEXTL-TEXT_LINE =
/THKR/V_GITEXTL-TEXT_LINE .
    IF SY-SUBRC = 0.
    UPDATE /THKR/C_GITEXTL ##WARN_OK.
    ELSE.
    INSERT /THKR/C_GITEXTL .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_GITEXTL-UPD_FLAG,
STATUS_/THKR/V_GITEXTL-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
*---------------------------------------------------------------------*
FORM READ_SINGLE_/THKR/V_GITEXTL.
  SELECT SINGLE * FROM /THKR/C_GITEXTL WHERE
TEXT_ID = /THKR/V_GITEXTL-TEXT_ID AND
LINE_NR = /THKR/V_GITEXTL-LINE_NR .
/THKR/V_GITEXTL-MANDT =
/THKR/C_GITEXTL-MANDT .
/THKR/V_GITEXTL-TEXT_ID =
/THKR/C_GITEXTL-TEXT_ID .
/THKR/V_GITEXTL-LINE_NR =
/THKR/C_GITEXTL-LINE_NR .
/THKR/V_GITEXTL-LF =
/THKR/C_GITEXTL-LF .
/THKR/V_GITEXTL-TEXT_LINE =
/THKR/C_GITEXTL-TEXT_LINE .
    SELECT SINGLE * FROM /THKR/C_GI_TEXT WHERE
TEXT_ID = /THKR/C_GITEXTL-TEXT_ID .
    IF SY-SUBRC EQ 0.
    ELSE.
      CLEAR SY-SUBRC.
    ENDIF.
ENDFORM.
*---------------------------------------------------------------------*
FORM CORR_MAINT_/THKR/V_GITEXTL USING VALUE(CM_ACTION) RC.
  DATA: RETCODE LIKE SY-SUBRC, COUNT TYPE I, TRSP_KEYLEN TYPE SYFLENG.
  FIELD-SYMBOLS: <TAB_KEY_X> TYPE X.
  CLEAR RC.
MOVE /THKR/V_GITEXTL-TEXT_ID TO
/THKR/C_GITEXTL-TEXT_ID .
MOVE /THKR/V_GITEXTL-LINE_NR TO
/THKR/C_GITEXTL-LINE_NR .
MOVE /THKR/V_GITEXTL-MANDT TO
/THKR/C_GITEXTL-MANDT .
  CORR_KEYTAB             =  E071K.
  CORR_KEYTAB-OBJNAME     = '/THKR/C_GITEXTL'.
  IF NOT <vim_corr_keyx> IS ASSIGNED.
    ASSIGN CORR_KEYTAB-TABKEY TO <vim_corr_keyx> CASTING.
  ENDIF.
  ASSIGN /THKR/C_GITEXTL TO <TAB_KEY_X> CASTING.
  PERFORM VIM_GET_TRSPKEYLEN
    USING '/THKR/C_GITEXTL'
    CHANGING TRSP_KEYLEN.
  <VIM_CORR_KEYX>(TRSP_KEYLEN) = <TAB_KEY_X>(TRSP_KEYLEN).
  PERFORM UPDATE_CORR_KEYTAB USING CM_ACTION RETCODE.
  ADD: RETCODE TO RC, 1 TO COUNT.
  IF RC LT COUNT AND CM_ACTION NE PRUEFEN.
    CLEAR RC.
  ENDIF.

ENDFORM.
