*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: /THKR/V_GIMPVAL.................................*
FORM GET_DATA_/THKR/V_GIMPVAL.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM /THKR/C_GIMPVAL WHERE
(VIM_WHERETAB) .
    CLEAR /THKR/V_GIMPVAL .
/THKR/V_GIMPVAL-MANDT =
/THKR/C_GIMPVAL-MANDT .
/THKR/V_GIMPVAL-GI_ID =
/THKR/C_GIMPVAL-GI_ID .
/THKR/V_GIMPVAL-GI_FIELD =
/THKR/C_GIMPVAL-GI_FIELD .
/THKR/V_GIMPVAL-GI_MC =
/THKR/C_GIMPVAL-GI_MC .
/THKR/V_GIMPVAL-GI_MP_TAB =
/THKR/C_GIMPVAL-GI_MP_TAB .
/THKR/V_GIMPVAL-LINE_KEY_VALUE =
/THKR/C_GIMPVAL-LINE_KEY_VALUE .
/THKR/V_GIMPVAL-LFD_NR =
/THKR/C_GIMPVAL-LFD_NR .
/THKR/V_GIMPVAL-SOURCE_VALUE =
/THKR/C_GIMPVAL-SOURCE_VALUE .
/THKR/V_GIMPVAL-TARGET_VALUE =
/THKR/C_GIMPVAL-TARGET_VALUE .
<VIM_TOTAL_STRUC> = /THKR/V_GIMPVAL.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_GIMPVAL .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_GIMPVAL.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_GIMPVAL-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIMPVAL WHERE
  GI_ID = /THKR/V_GIMPVAL-GI_ID AND
  GI_FIELD = /THKR/V_GIMPVAL-GI_FIELD AND
  GI_MC = /THKR/V_GIMPVAL-GI_MC AND
  GI_MP_TAB = /THKR/V_GIMPVAL-GI_MP_TAB AND
  LINE_KEY_VALUE = /THKR/V_GIMPVAL-LINE_KEY_VALUE AND
  LFD_NR = /THKR/V_GIMPVAL-LFD_NR AND
  SOURCE_VALUE = /THKR/V_GIMPVAL-SOURCE_VALUE .
    IF SY-SUBRC = 0.
    DELETE /THKR/C_GIMPVAL .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIMPVAL WHERE
  GI_ID = /THKR/V_GIMPVAL-GI_ID AND
  GI_FIELD = /THKR/V_GIMPVAL-GI_FIELD AND
  GI_MC = /THKR/V_GIMPVAL-GI_MC AND
  GI_MP_TAB = /THKR/V_GIMPVAL-GI_MP_TAB AND
  LINE_KEY_VALUE = /THKR/V_GIMPVAL-LINE_KEY_VALUE AND
  LFD_NR = /THKR/V_GIMPVAL-LFD_NR AND
  SOURCE_VALUE = /THKR/V_GIMPVAL-SOURCE_VALUE .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/C_GIMPVAL.
    ENDIF.
/THKR/C_GIMPVAL-MANDT =
/THKR/V_GIMPVAL-MANDT .
/THKR/C_GIMPVAL-GI_ID =
/THKR/V_GIMPVAL-GI_ID .
/THKR/C_GIMPVAL-GI_FIELD =
/THKR/V_GIMPVAL-GI_FIELD .
/THKR/C_GIMPVAL-GI_MC =
/THKR/V_GIMPVAL-GI_MC .
/THKR/C_GIMPVAL-GI_MP_TAB =
/THKR/V_GIMPVAL-GI_MP_TAB .
/THKR/C_GIMPVAL-LINE_KEY_VALUE =
/THKR/V_GIMPVAL-LINE_KEY_VALUE .
/THKR/C_GIMPVAL-LFD_NR =
/THKR/V_GIMPVAL-LFD_NR .
/THKR/C_GIMPVAL-SOURCE_VALUE =
/THKR/V_GIMPVAL-SOURCE_VALUE .
/THKR/C_GIMPVAL-TARGET_VALUE =
/THKR/V_GIMPVAL-TARGET_VALUE .
    IF SY-SUBRC = 0.
    UPDATE /THKR/C_GIMPVAL ##WARN_OK.
    ELSE.
    INSERT /THKR/C_GIMPVAL .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_GIMPVAL-UPD_FLAG,
STATUS_/THKR/V_GIMPVAL-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
