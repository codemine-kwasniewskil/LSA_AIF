FORM CORR_MAINT_/THKR/V_GIMPVAL USING VALUE(CM_ACTION) RC.
  DATA: RETCODE LIKE SY-SUBRC, COUNT TYPE I, TRSP_KEYLEN TYPE SYFLENG.
  FIELD-SYMBOLS: <TAB_KEY_X> TYPE X.
  CLEAR RC.
MOVE /THKR/V_GIMPVAL-GI_ID TO
/THKR/C_GIMPVAL-GI_ID .
MOVE /THKR/V_GIMPVAL-GI_FIELD TO
/THKR/C_GIMPVAL-GI_FIELD .
MOVE /THKR/V_GIMPVAL-GI_MC TO
/THKR/C_GIMPVAL-GI_MC .
MOVE /THKR/V_GIMPVAL-GI_MP_TAB TO
/THKR/C_GIMPVAL-GI_MP_TAB .
MOVE /THKR/V_GIMPVAL-LINE_KEY_VALUE TO
/THKR/C_GIMPVAL-LINE_KEY_VALUE .
MOVE /THKR/V_GIMPVAL-LFD_NR TO
/THKR/C_GIMPVAL-LFD_NR .
MOVE /THKR/V_GIMPVAL-SOURCE_VALUE TO
/THKR/C_GIMPVAL-SOURCE_VALUE .
MOVE /THKR/V_GIMPVAL-MANDT TO
/THKR/C_GIMPVAL-MANDT .
  CORR_KEYTAB             =  E071K.
  CORR_KEYTAB-OBJNAME     = '/THKR/C_GIMPVAL'.
  IF NOT <vim_corr_keyx> IS ASSIGNED.
    ASSIGN CORR_KEYTAB-TABKEY TO <vim_corr_keyx> CASTING.
  ENDIF.
  ASSIGN /THKR/C_GIMPVAL TO <TAB_KEY_X> CASTING.
  PERFORM VIM_GET_TRSPKEYLEN
    USING '/THKR/C_GIMPVAL'
    CHANGING TRSP_KEYLEN.
  <VIM_CORR_KEYX>(TRSP_KEYLEN) = <TAB_KEY_X>(TRSP_KEYLEN).
  PERFORM UPDATE_CORR_KEYTAB USING CM_ACTION RETCODE.
  ADD: RETCODE TO RC, 1 TO COUNT.
  IF RC LT COUNT AND CM_ACTION NE PRUEFEN.
    CLEAR RC.
  ENDIF.

ENDFORM.
