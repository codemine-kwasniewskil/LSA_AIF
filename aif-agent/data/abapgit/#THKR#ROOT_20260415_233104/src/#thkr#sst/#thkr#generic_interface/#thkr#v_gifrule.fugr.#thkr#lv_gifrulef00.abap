*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: /THKR/V_GIFRULE.................................*
FORM GET_DATA_/THKR/V_GIFRULE.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM /THKR/C_GIFRULE WHERE
(VIM_WHERETAB) .
    CLEAR /THKR/V_GIFRULE .
/THKR/V_GIFRULE-MANDT =
/THKR/C_GIFRULE-MANDT .
/THKR/V_GIFRULE-FILTER_ID =
/THKR/C_GIFRULE-FILTER_ID .
/THKR/V_GIFRULE-RULE_ID =
/THKR/C_GIFRULE-RULE_ID .
/THKR/V_GIFRULE-PARENT_RULE_ID =
/THKR/C_GIFRULE-PARENT_RULE_ID .
/THKR/V_GIFRULE-RULE_TYPE =
/THKR/C_GIFRULE-RULE_TYPE .
/THKR/V_GIFRULE-DESCRIPTION =
/THKR/C_GIFRULE-DESCRIPTION .
/THKR/V_GIFRULE-RECORD_FLD =
/THKR/C_GIFRULE-RECORD_FLD .
/THKR/V_GIFRULE-FILTER_OPTION =
/THKR/C_GIFRULE-FILTER_OPTION .
/THKR/V_GIFRULE-FIXED_VALUE =
/THKR/C_GIFRULE-FIXED_VALUE .
<VIM_TOTAL_STRUC> = /THKR/V_GIFRULE.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_GIFRULE .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_GIFRULE.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_GIFRULE-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIFRULE WHERE
  FILTER_ID = /THKR/V_GIFRULE-FILTER_ID AND
  RULE_ID = /THKR/V_GIFRULE-RULE_ID .
    IF SY-SUBRC = 0.
    DELETE /THKR/C_GIFRULE .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIFRULE WHERE
  FILTER_ID = /THKR/V_GIFRULE-FILTER_ID AND
  RULE_ID = /THKR/V_GIFRULE-RULE_ID .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/C_GIFRULE.
    ENDIF.
/THKR/C_GIFRULE-MANDT =
/THKR/V_GIFRULE-MANDT .
/THKR/C_GIFRULE-FILTER_ID =
/THKR/V_GIFRULE-FILTER_ID .
/THKR/C_GIFRULE-RULE_ID =
/THKR/V_GIFRULE-RULE_ID .
/THKR/C_GIFRULE-PARENT_RULE_ID =
/THKR/V_GIFRULE-PARENT_RULE_ID .
/THKR/C_GIFRULE-RULE_TYPE =
/THKR/V_GIFRULE-RULE_TYPE .
/THKR/C_GIFRULE-DESCRIPTION =
/THKR/V_GIFRULE-DESCRIPTION .
/THKR/C_GIFRULE-RECORD_FLD =
/THKR/V_GIFRULE-RECORD_FLD .
/THKR/C_GIFRULE-FILTER_OPTION =
/THKR/V_GIFRULE-FILTER_OPTION .
/THKR/C_GIFRULE-FIXED_VALUE =
/THKR/V_GIFRULE-FIXED_VALUE .
    IF SY-SUBRC = 0.
    UPDATE /THKR/C_GIFRULE ##WARN_OK.
    ELSE.
    INSERT /THKR/C_GIFRULE .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_GIFRULE-UPD_FLAG,
STATUS_/THKR/V_GIFRULE-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
