*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_GIMPTAB .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_GIMPTAB.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_GIMPTAB-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIMPTAB WHERE
  GI_ID = /THKR/V_GIMPTAB-GI_ID AND
  GI_MC = /THKR/V_GIMPTAB-GI_MC AND
  GI_MP_TAB = /THKR/V_GIMPTAB-GI_MP_TAB .
    IF SY-SUBRC = 0.
    DELETE /THKR/C_GIMPTAB .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIMPTAB WHERE
  GI_ID = /THKR/V_GIMPTAB-GI_ID AND
  GI_MC = /THKR/V_GIMPTAB-GI_MC AND
  GI_MP_TAB = /THKR/V_GIMPTAB-GI_MP_TAB .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/C_GIMPTAB.
    ENDIF.
/THKR/C_GIMPTAB-MANDT =
/THKR/V_GIMPTAB-MANDT .
/THKR/C_GIMPTAB-GI_ID =
/THKR/V_GIMPTAB-GI_ID .
/THKR/C_GIMPTAB-GI_MC =
/THKR/V_GIMPTAB-GI_MC .
/THKR/C_GIMPTAB-GI_MP_TAB =
/THKR/V_GIMPTAB-GI_MP_TAB .
/THKR/C_GIMPTAB-SEQ_NO =
/THKR/V_GIMPTAB-SEQ_NO .
/THKR/C_GIMPTAB-MP_TAB_TYPE =
/THKR/V_GIMPTAB-MP_TAB_TYPE .
/THKR/C_GIMPTAB-DESCRIPTION =
/THKR/V_GIMPTAB-DESCRIPTION .
/THKR/C_GIMPTAB-TABLE_FIELD =
/THKR/V_GIMPTAB-TABLE_FIELD .
/THKR/C_GIMPTAB-FIXED_LINE_NR =
/THKR/V_GIMPTAB-FIXED_LINE_NR .
/THKR/C_GIMPTAB-TABLE_FIELD_STRUCT =
/THKR/V_GIMPTAB-TABLE_FIELD_STRUCT .
/THKR/C_GIMPTAB-DTO_FIELD =
/THKR/V_GIMPTAB-DTO_FIELD .
/THKR/C_GIMPTAB-DTO_FIELD_LINE_KEY =
/THKR/V_GIMPTAB-DTO_FIELD_LINE_KEY .
/THKR/C_GIMPTAB-DTO_FIELD_LINE_KEY2 =
/THKR/V_GIMPTAB-DTO_FIELD_LINE_KEY2 .
/THKR/C_GIMPTAB-DTO_FIELD_LINE_KEY3 =
/THKR/V_GIMPTAB-DTO_FIELD_LINE_KEY3 .
/THKR/C_GIMPTAB-DTO_FIELD_LINE_NR =
/THKR/V_GIMPTAB-DTO_FIELD_LINE_NR .
/THKR/C_GIMPTAB-DTO_FIELD_STRUCT =
/THKR/V_GIMPTAB-DTO_FIELD_STRUCT .
    IF SY-SUBRC = 0.
    UPDATE /THKR/C_GIMPTAB ##WARN_OK.
    ELSE.
    INSERT /THKR/C_GIMPTAB .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_GIMPTAB-UPD_FLAG,
STATUS_/THKR/V_GIMPTAB-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
