*---------------------------------------------------------------------*
*    view related FORM routines
*---------------------------------------------------------------------*
*...processing: /THKR/V_GI_F_PAR................................*
FORM GET_DATA_/THKR/V_GI_F_PAR.
  PERFORM VIM_FILL_WHERETAB.
*.read data from database.............................................*
  REFRESH TOTAL.
  CLEAR   TOTAL.
  SELECT * FROM /THKR/C_GIFPAR WHERE
(VIM_WHERETAB) .
    CLEAR /THKR/V_GI_F_PAR .
/THKR/V_GI_F_PAR-MANDT =
/THKR/C_GIFPAR-MANDT .
/THKR/V_GI_F_PAR-FILTER_ID =
/THKR/C_GIFPAR-FILTER_ID .
/THKR/V_GI_F_PAR-PARAM =
/THKR/C_GIFPAR-PARAM .
/THKR/V_GI_F_PAR-DESCRIPTION =
/THKR/C_GIFPAR-DESCRIPTION .
<VIM_TOTAL_STRUC> = /THKR/V_GI_F_PAR.
    APPEND TOTAL.
  ENDSELECT.
  SORT TOTAL BY <VIM_XTOTAL_KEY>.
  <STATUS>-ALR_SORTED = 'R'.
*.check dynamic selectoptions (not in DDIC)...........................*
  IF X_HEADER-SELECTION NE SPACE.
    PERFORM CHECK_DYNAMIC_SELECT_OPTIONS.
  ELSEIF X_HEADER-DELMDTFLAG NE SPACE.
    PERFORM BUILD_MAINKEY_TAB.
  ENDIF.
  REFRESH EXTRACT.
ENDFORM.
*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_GI_F_PAR .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_GI_F_PAR.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_GI_F_PAR-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIFPAR WHERE
  FILTER_ID = /THKR/V_GI_F_PAR-FILTER_ID AND
  PARAM = /THKR/V_GI_F_PAR-PARAM .
    IF SY-SUBRC = 0.
    DELETE /THKR/C_GIFPAR .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GIFPAR WHERE
  FILTER_ID = /THKR/V_GI_F_PAR-FILTER_ID AND
  PARAM = /THKR/V_GI_F_PAR-PARAM .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/C_GIFPAR.
    ENDIF.
/THKR/C_GIFPAR-MANDT =
/THKR/V_GI_F_PAR-MANDT .
/THKR/C_GIFPAR-FILTER_ID =
/THKR/V_GI_F_PAR-FILTER_ID .
/THKR/C_GIFPAR-PARAM =
/THKR/V_GI_F_PAR-PARAM .
/THKR/C_GIFPAR-DESCRIPTION =
/THKR/V_GI_F_PAR-DESCRIPTION .
    IF SY-SUBRC = 0.
    UPDATE /THKR/C_GIFPAR ##WARN_OK.
    ELSE.
    INSERT /THKR/C_GIFPAR .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_GI_F_PAR-UPD_FLAG,
STATUS_/THKR/V_GI_F_PAR-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
*---------------------------------------------------------------------*
FORM READ_SINGLE_/THKR/V_GI_F_PAR.
  SELECT SINGLE * FROM /THKR/C_GIFPAR WHERE
FILTER_ID = /THKR/V_GI_F_PAR-FILTER_ID AND
PARAM = /THKR/V_GI_F_PAR-PARAM .
/THKR/V_GI_F_PAR-MANDT =
/THKR/C_GIFPAR-MANDT .
/THKR/V_GI_F_PAR-FILTER_ID =
/THKR/C_GIFPAR-FILTER_ID .
/THKR/V_GI_F_PAR-PARAM =
/THKR/C_GIFPAR-PARAM .
/THKR/V_GI_F_PAR-DESCRIPTION =
/THKR/C_GIFPAR-DESCRIPTION .
ENDFORM.
*---------------------------------------------------------------------*
FORM CORR_MAINT_/THKR/V_GI_F_PAR USING VALUE(CM_ACTION) RC.
  DATA: RETCODE LIKE SY-SUBRC, COUNT TYPE I, TRSP_KEYLEN TYPE SYFLENG.
  FIELD-SYMBOLS: <TAB_KEY_X> TYPE X.
  CLEAR RC.
MOVE /THKR/V_GI_F_PAR-FILTER_ID TO
/THKR/C_GIFPAR-FILTER_ID .
MOVE /THKR/V_GI_F_PAR-PARAM TO
/THKR/C_GIFPAR-PARAM .
MOVE /THKR/V_GI_F_PAR-MANDT TO
/THKR/C_GIFPAR-MANDT .
  CORR_KEYTAB             =  E071K.
  CORR_KEYTAB-OBJNAME     = '/THKR/C_GIFPAR'.
  IF NOT <vim_corr_keyx> IS ASSIGNED.
    ASSIGN CORR_KEYTAB-TABKEY TO <vim_corr_keyx> CASTING.
  ENDIF.
  ASSIGN /THKR/C_GIFPAR TO <TAB_KEY_X> CASTING.
  PERFORM VIM_GET_TRSPKEYLEN
    USING '/THKR/C_GIFPAR'
    CHANGING TRSP_KEYLEN.
  <VIM_CORR_KEYX>(TRSP_KEYLEN) = <TAB_KEY_X>(TRSP_KEYLEN).
  PERFORM UPDATE_CORR_KEYTAB USING CM_ACTION RETCODE.
  ADD: RETCODE TO RC, 1 TO COUNT.
  IF RC LT COUNT AND CM_ACTION NE PRUEFEN.
    CLEAR RC.
  ENDIF.

ENDFORM.
