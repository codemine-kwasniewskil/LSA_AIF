*---------------------------------------------------------------------*
FORM DB_UPD_/THKR/V_GI_MC .
*.process data base updates/inserts/deletes.........................*
LOOP AT TOTAL.
  CHECK <ACTION> NE ORIGINAL.
MOVE <VIM_TOTAL_STRUC> TO /THKR/V_GI_MC.
  IF <ACTION> = UPDATE_GELOESCHT.
    <ACTION> = GELOESCHT.
  ENDIF.
  CASE <ACTION>.
   WHEN NEUER_GELOESCHT.
IF STATUS_/THKR/V_GI_MC-ST_DELETE EQ GELOESCHT.
     READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
     IF SY-SUBRC EQ 0.
       DELETE EXTRACT INDEX SY-TABIX.
     ENDIF.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN GELOESCHT.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GI_MC WHERE
  GI_ID = /THKR/V_GI_MC-GI_ID AND
  GI_MC = /THKR/V_GI_MC-GI_MC .
    IF SY-SUBRC = 0.
    DELETE /THKR/C_GI_MC .
    ENDIF.
    IF STATUS-DELETE EQ GELOESCHT.
      READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY> BINARY SEARCH.
      DELETE EXTRACT INDEX SY-TABIX.
    ENDIF.
    DELETE TOTAL.
    IF X_HEADER-DELMDTFLAG NE SPACE.
      PERFORM DELETE_FROM_MAINKEY_TAB.
    ENDIF.
   WHEN OTHERS.
  SELECT SINGLE FOR UPDATE * FROM /THKR/C_GI_MC WHERE
  GI_ID = /THKR/V_GI_MC-GI_ID AND
  GI_MC = /THKR/V_GI_MC-GI_MC .
    IF SY-SUBRC <> 0.   "insert preprocessing: init WA
      CLEAR /THKR/C_GI_MC.
    ENDIF.
/THKR/C_GI_MC-MANDT =
/THKR/V_GI_MC-MANDT .
/THKR/C_GI_MC-GI_ID =
/THKR/V_GI_MC-GI_ID .
/THKR/C_GI_MC-GI_MC =
/THKR/V_GI_MC-GI_MC .
/THKR/C_GI_MC-SEQ_NO =
/THKR/V_GI_MC-SEQ_NO .
/THKR/C_GI_MC-DATA_SOURCE =
/THKR/V_GI_MC-DATA_SOURCE .
/THKR/C_GI_MC-INT_CLS =
/THKR/V_GI_MC-INT_CLS .
/THKR/C_GI_MC-INT_METHODE =
/THKR/V_GI_MC-INT_METHODE .
/THKR/C_GI_MC-DESCRIPTION =
/THKR/V_GI_MC-DESCRIPTION .
/THKR/C_GI_MC-RESTRICTION_PARAM =
/THKR/V_GI_MC-RESTRICTION_PARAM .
/THKR/C_GI_MC-RESTRICTION_VALUE =
/THKR/V_GI_MC-RESTRICTION_VALUE .
/THKR/C_GI_MC-RESTRICTION_PARAM_OPT =
/THKR/V_GI_MC-RESTRICTION_PARAM_OPT .
    IF SY-SUBRC = 0.
    UPDATE /THKR/C_GI_MC ##WARN_OK.
    ELSE.
    INSERT /THKR/C_GI_MC .
    ENDIF.
    READ TABLE EXTRACT WITH KEY <VIM_XTOTAL_KEY>.
    IF SY-SUBRC EQ 0.
      <XACT> = ORIGINAL.
      MODIFY EXTRACT INDEX SY-TABIX.
    ENDIF.
    <ACTION> = ORIGINAL.
    MODIFY TOTAL.
  ENDCASE.
ENDLOOP.
CLEAR: STATUS_/THKR/V_GI_MC-UPD_FLAG,
STATUS_/THKR/V_GI_MC-UPD_CHECKD.
MESSAGE S018(SV).
ENDFORM.
